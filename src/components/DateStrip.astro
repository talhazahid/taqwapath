---
const todayHijri = "Loading Hijri date...";
const todayGreg = "Loading date...";
---
<section class="date-strip">
  <div class="container date-strip__inner">
    <div class="date-pill">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path
          d="M6 4v3M18 4v3M4 9h16M6 12h4M6 16h8"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
        />
        <rect x="4" y="6" width="16" height="14" rx="2.5" stroke="currentColor" stroke-width="1.6" />
      </svg>
      <span>Today's Islamic date: <strong data-hijri-date>{todayHijri}</strong></span>
    </div>
    <span class="muted" data-gregorian-date>{todayGreg}</span>
  </div>
</section>

<script is:inline>
  const initHijriStrip = () => {
    const hijriEl = document.querySelector("[data-hijri-date]");
    const gregEl = document.querySelector("[data-gregorian-date]");

    if (!hijriEl && !gregEl) return;

    const formatGregorian = (date) =>
      new Intl.DateTimeFormat("en", {
        weekday: "short",
        month: "short",
        day: "2-digit",
        year: "numeric"
      }).format(date);

    const setFallback = () => {
      const now = new Date();
      if (gregEl) gregEl.textContent = formatGregorian(now);
      if (hijriEl) {
        const hijriText = new Intl.DateTimeFormat("en-u-ca-islamic", {
          day: "numeric",
          month: "long",
          year: "numeric"
        }).format(now);
        hijriEl.textContent = hijriText;
      }
    };

    const fetchHijriDate = async () => {
      try {
        const now = new Date();
        const day = String(now.getDate()).padStart(2, "0");
        const month = String(now.getMonth() + 1).padStart(2, "0");
        const year = now.getFullYear();
        const response = await fetch(`https://api.aladhan.com/v1/gToH?date=${day}-${month}-${year}`);
        if (!response.ok) throw new Error("Failed to fetch Hijri date.");
        const payload = await response.json();
        const hijri = payload?.data?.hijri;
        if (!hijri) throw new Error("No Hijri data.");
        const hijriMonth = hijri.month?.en || "Hijri";
        if (hijriEl) hijriEl.textContent = `${hijri.day} ${hijriMonth} ${hijri.year}`;
        if (gregEl) gregEl.textContent = formatGregorian(now);
      } catch {
        setFallback();
      }
    };

    fetchHijriDate();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHijriStrip);
  } else {
    initHijriStrip();
  }
</script>
