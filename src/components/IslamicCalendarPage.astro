---
import fs from "node:fs/promises";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  ALL_CALENDAR_YEARS,
  MONTH_NAMES,
  formatGregorianLong
} from "../lib/calendarData.js";

const { year } = Astro.props;

const calendarPath = path.join(process.cwd(), "public", "data", "islamic-calendar", `${year}.json`);
const calendarPayload = JSON.parse(await fs.readFile(calendarPath, "utf8"));
const currentDate = new Date();
const startOfToday = new Date(currentDate.getFullYear(), currentDate.getMonth(), currentDate.getDate());
const initialMonth = currentDate.getFullYear() === year ? currentDate.getMonth() + 1 : 1;
const initialMonthName = MONTH_NAMES[initialMonth - 1];
const monthOrder = Object.keys(calendarPayload?.months || {}).sort((a, b) => Number(a) - Number(b));
const initialMonthData = Array.isArray(calendarPayload?.months?.[String(initialMonth)])
  ? calendarPayload.months[String(initialMonth)]
  : [];
const cleanHoliday = (holiday) => String(holiday || "").replace(/\(.*?\)/g, "").trim();
const normalizeHolidayKey = (holiday) =>
  cleanHoliday(holiday)
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, " ")
    .trim();
const allowedHolidayKeys = new Set([
  "lailat ul miraj",
  "lailat ul bara at",
  "1st day of ramadan",
  "lailat ul qadr",
  "eid ul fitr",
  "hajj",
  "arafa",
  "eid ul adha",
  "1st day of muharram",
  "ashura",
  "mawlid al nabi",
  "mawlid of the prophet",
  "mawlid birth al nabi",
  "beginning of the holy months",
  "end of the holy months",
  "treaty of hudaybiyya",
  "first time adhan was called in 622 ad"
]);
const isIslamicHolidayEvent = (holiday) => allowedHolidayKeys.has(normalizeHolidayKey(holiday));
const majorHolidayKeys = new Set([
  "1st day of ramadan",
  "lailat ul qadr",
  "eid ul fitr",
  "hajj",
  "arafa",
  "eid ul adha",
  "1st day of muharram",
  "ashura",
  "mawlid al nabi",
  "mawlid of the prophet",
  "mawlid birth al nabi"
]);
const isMajorHoliday = (holiday) => majorHolidayKeys.has(normalizeHolidayKey(holiday));
const normalizeHijriMonthName = (month) => {
  const normalized = String(month || "")
    .toLowerCase()
    .replace(/[^a-z]/g, "");
  const monthMap = new Map([
    ["muharram", "Muharram"],
    ["muarram", "Muharram"],
    ["safar", "Safar"],
    ["afar", "Safar"],
    ["rabialawwal", "Rabi al-Awwal"],
    ["rabialthani", "Rabi al-Thani"],
    ["jumadaalawwal", "Jumada al-Awwal"],
    ["jumadaalthani", "Jumada al-Thani"],
    ["rajab", "Rajab"],
    ["shaban", "Shaban"],
    ["shaaban", "Shaban"],
    ["ramadan", "Ramadan"],
    ["shawwal", "Shawwal"],
    ["dhualqidah", "Dhu al-Qidah"],
    ["dhalqidah", "Dhu al-Qidah"],
    ["dhalqadah", "Dhu al-Qidah"],
    ["dhualhijjah", "Dhu al-Hijjah"],
    ["dhalijjah", "Dhu al-Hijjah"],
    ["dhalhijjah", "Dhu al-Hijjah"]
  ]);
  return monthMap.get(normalized) || String(month || "").trim();
};
const formatHijriDate = (hijri, dayOverride = hijri?.day) => {
  if (!dayOverride || !hijri?.month?.en || !hijri?.year) return "";
  return `${dayOverride} ${normalizeHijriMonthName(hijri.month.en)} ${hijri.year}`;
};

const formatSpecialTitle = (holiday) => {
  const normalized = normalizeHolidayKey(holiday);
  const titleMap = new Map([
    ["lailat ul miraj", "Shab e Meraj"],
    ["lailat ul bara at", "Shab e Barat"],
    ["1st day of ramadan", "1st Ramadan"],
    ["lailat ul qadr", "Laylat al Qadr"],
    ["eid ul fitr", "Eid ul Fitr"],
    ["hajj", "Hajj"],
    ["arafa", "Day of Arafah"],
    ["eid ul adha", "Eid ul Adha"],
    ["1st day of muharram", "1st Muharram (New Year)"],
    ["ashura", "10 Muharram (Ashura)"],
    ["mawlid birth al nabi", "Mawlid al Nabi"],
    ["beginning of the holy months", "Beginning of the holy months"],
    ["end of the holy months", "End of the holy months"],
    ["treaty of hudaybiyya", "Treaty of Hudaybiyya"]
  ]);
  return titleMap.get(normalized) || cleanHoliday(holiday).replace(/[-_]+/g, " ");
};

const collectSpecialDays = (months) => {
  const seen = new Set();
  const events = [];

  monthOrder.forEach((monthKey) => {
    const monthDays = Array.isArray(months?.[monthKey]) ? months[monthKey] : [];
    monthDays.forEach((day) => {
      const holidays = Array.isArray(day?.hijri?.holidays) ? day.hijri.holidays : [];
      holidays.forEach((holiday) => {
        const label = cleanHoliday(holiday);
        if (!label || !isIslamicHolidayEvent(label)) return;
        const key = normalizeHolidayKey(label);
        if (seen.has(key)) return;
        const gregorianDate = new Date(year, Number(monthKey) - 1, Number(day?.gregorian?.day));
        if (Number.isNaN(gregorianDate.getTime())) return;
        if (gregorianDate < startOfToday) return;
        seen.add(key);
        events.push({
          title: formatSpecialTitle(label),
          gregorian: formatGregorianLong(gregorianDate),
          month: new Intl.DateTimeFormat("en", { month: "short" }).format(gregorianDate),
          day: String(gregorianDate.getDate()).padStart(2, "0"),
          hijri: formatHijriDate(day.hijri)
        });
      });
    });
  });

  if (!events.length) {
    monthOrder.forEach((monthKey) => {
      const monthDays = Array.isArray(months?.[monthKey]) ? months[monthKey] : [];
      monthDays.forEach((day) => {
        const holidays = Array.isArray(day?.hijri?.holidays) ? day.hijri.holidays : [];
        holidays.forEach((holiday) => {
          const label = cleanHoliday(holiday);
          if (!label || !isIslamicHolidayEvent(label)) return;
          const key = normalizeHolidayKey(label);
          if (seen.has(key)) return;
          const gregorianDate = new Date(year, Number(monthKey) - 1, Number(day?.gregorian?.day));
          if (Number.isNaN(gregorianDate.getTime())) return;
          seen.add(key);
          events.push({
            title: formatSpecialTitle(label),
            gregorian: formatGregorianLong(gregorianDate),
            month: new Intl.DateTimeFormat("en", { month: "short" }).format(gregorianDate),
            day: String(gregorianDate.getDate()).padStart(2, "0"),
            hijri: formatHijriDate(day.hijri)
          });
        });
      });
    });
  }

  return events.slice(0, 10);
};

const initialSpecialDays = collectSpecialDays(calendarPayload?.months || {});
const initialSpecialDaysMarkup = initialSpecialDays
  .map(
    (item) => `
      <div class="special-day">
        <div class="special-day__date">
          <span class="special-day__month">${item.month}</span>
          <span class="special-day__day">${item.day}</span>
        </div>
        <div class="special-day__body">
          <div class="special-day__title">${item.title}</div>
          <div class="special-day__meta">${item.hijri}</div>
        </div>
        <div class="special-day__right">${item.gregorian}</div>
      </div>
    `
  )
  .join("");
const initialTodayHijriEntry =
  currentDate.getFullYear() === year
    ? initialMonthData.find((day) => Number(day?.gregorian?.day) === currentDate.getDate())
    : initialMonthData[0];
const initialTodayHijri = initialTodayHijriEntry?.hijri?.day && initialTodayHijriEntry?.hijri?.month?.en && initialTodayHijriEntry?.hijri?.year
  ? `${initialTodayHijriEntry.hijri.day} ${normalizeHijriMonthName(initialTodayHijriEntry.hijri.month.en)}, ${initialTodayHijriEntry.hijri.year}`
  : "Loading...";

const findHijriDay = (monthName, dayNumber) => {
  for (const monthKey of monthOrder) {
    const monthDays = Array.isArray(calendarPayload?.months?.[monthKey]) ? calendarPayload.months[monthKey] : [];
    const match = monthDays.find((day) =>
      Number(day?.hijri?.day) === dayNumber &&
      normalizeHijriMonthName(day?.hijri?.month?.en) === monthName
    );
    if (match) return { ...match, monthKey };
  }
  return null;
};
const formatCalendarEntryDate = (entry) => {
  if (!entry?.monthKey || !entry?.gregorian?.day) return "an estimated date listed in the calendar";
  const gregorianDate = new Date(year, Number(entry.monthKey) - 1, Number(entry.gregorian.day));
  return Number.isNaN(gregorianDate.getTime()) ? "an estimated date listed in the calendar" : formatGregorianLong(gregorianDate);
};
const muharramStart = findHijriDay("Muharram", 1);
const eidAlFitr = findHijriDay("Shawwal", 1);
const hajjStart = findHijriDay("Dhu al-Hijjah", 8) || findHijriDay("Dhu al-Hijjah", 9);
const arafahDay = findHijriDay("Dhu al-Hijjah", 9);
const calendarFaqItems = [
  {
    question: "What is the Islamic date today?",
    answer: currentDate.getFullYear() === year
      ? `Today’s estimated Islamic date in Karachi is ${initialTodayHijri}. Local moon sighting can shift the date.`
      : `This ${year} page shows estimated Hijri dates for each Gregorian day. Use the calendar grid to compare Islamic and Gregorian dates.`
  },
  {
    question: "What is today in Hijri?",
    answer: currentDate.getFullYear() === year
      ? `Today in Hijri is estimated as ${initialTodayHijri} for Karachi. Confirm local rulings for worship dates.`
      : `For ${year}, select any day in the calendar grid to see its estimated Hijri date.`
  },
  {
    question: "What is the Hijri date now?",
    answer: currentDate.getFullYear() === year
      ? `The current estimated Hijri date shown on this page is ${initialTodayHijri}.`
      : `The ${year} calendar maps each Gregorian date to an estimated Hijri date for planning.`
  },
  {
    question: "What date is today in the Arabic calendar?",
    answer: currentDate.getFullYear() === year
      ? `The Arabic or Hijri calendar date today is estimated as ${initialTodayHijri}.`
      : `Use the ${year} calendar grid to find the Arabic or Hijri date for any Gregorian day in that year.`
  },
  {
    question: `What is the Islamic calendar ${year}?`,
    answer: `The Islamic calendar ${year} page lists estimated Hijri dates, Gregorian dates, and major Islamic events for ${year}.`
  },
  {
    question: `When is Hajj ${year}?`,
    answer: `Hajj ${year} is estimated around ${formatCalendarEntryDate(hajjStart)}. Day of Arafah is estimated around ${formatCalendarEntryDate(arafahDay)}.`
  },
  {
    question: `When is Eid al Fitr ${year}?`,
    answer: `Eid al Fitr ${year} is estimated around ${formatCalendarEntryDate(eidAlFitr)}, subject to moon sighting.`
  },
  {
    question: `When is Eid ul Fitr ${year}?`,
    answer: `Eid ul Fitr ${year} is another spelling for Eid al Fitr and is estimated around ${formatCalendarEntryDate(eidAlFitr)}.`
  },
  {
    question: `When is Muharram ${year}?`,
    answer: `1 Muharram in ${year} is estimated around ${formatCalendarEntryDate(muharramStart)}, subject to local moon sighting.`
  }
];
---
<BaseLayout
  title={`Islamic Calendar ${year} (Hijri & Gregorian) - TaqwaPath`}
  description={`${year} Hijri and Gregorian calendar with Islamic dates, holidays, and monthly views. Dates are estimated and may vary by moon sighting.`}
  faqItems={calendarFaqItems}
>
  <section class="section">
    <div class="container calendar-container">
      <span class="pill">Islamic Calendar {year}</span>
      <h1 class="section-title">Islamic Calendar {year}</h1>
      <p class="section-lead">
        Estimated Hijri and Gregorian dates for {year}. Use this page for planning, indexing, and internal linking while keeping in mind that moon sighting can shift dates by a day.
      </p>

      <div class="calendar-controls">
        <select class="select" data-calendar-year>
          {Array.from({ length: 2040 - 2026 + 1 }, (_, i) => 2026 + i).map((y) => (
            <option value={y} selected={y === year}>{y}</option>
          ))}
        </select>
        <select class="select" data-calendar-month>
          {MONTH_NAMES.map((monthName, index) => (
            <option value={index + 1}>{monthName}</option>
          ))}
        </select>
        <select class="select" data-calendar-adjustment>
          <option value="0">0 days</option>
          <option value="1">+1 day</option>
          <option value="-1">-1 day</option>
          <option value="2">+2 days</option>
          <option value="-2">-2 days</option>
        </select>
      </div>

      <div class="calendar-nav-wrap">
        <button class="icon-btn" id="prev-month" aria-label="Previous Month">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="tag" data-calendar-title style="margin: 0;">{initialMonthName} {year}</div>
        <button class="icon-btn" id="next-month" aria-label="Next Month">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>

      <style>
        .calendar-nav-wrap {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 20px;
          margin: 20px 0;
        }
        .calendar-nav-wrap .tag {
          font-size: 1.4rem;
          font-weight: 600;
          color: var(--color-ink);
          background: transparent;
          padding: 0;
        }
        @media (max-width: 640px) {
          .calendar-container {
            display: flex;
            flex-direction: column;
          }
          .pill { order: 1; }
          .section-title { order: 2; }
          .section-lead { order: 3; }
          .calendar-controls { order: 4; }
          .calendar-nav-wrap { order: 5; }
          .calendar-grid { order: 6; }
          #special-islamic-days { order: 7; }
          .calendar-detail { order: 8; }
          .calendar-intro { order: 9; }
        }
      </style>

      <div class="calendar-grid" data-calendar-grid>
        <div class="card" style="grid-column: 1 / -1;">Loading calendar...</div>
      </div>

      <div class="card card--white calendar-intro" style="margin: 24px 0;">
        <div class="card__title">
          {currentDate.getFullYear() === year ? "Today Hijri Date in Karachi" : `Opening Hijri date for January ${year}`} -
          <span data-calendar-today-hijri>{initialTodayHijri}</span>
        </div>
        <p class="section-lead calendar-intro__text" style="margin-bottom: 14px;">
          Islamic months depend on lunar observation. Future Hijri dates and special events in {year} should be treated as estimated planning references, not final local rulings.
        </p>
        <p class="section-lead calendar-intro__text" style="margin-bottom: 0;">
          This page keeps Hijri and Gregorian dates together so the year can be indexed cleanly and used as an internal linking target.
        </p>
        <p class="section-lead calendar-intro__text" data-calendar-source style="margin-top: 12px; margin-bottom: 0;">
          Calendar source: loading latest Hijri data.
        </p>
      </div>

      <div class="card card--white calendar-detail" data-calendar-detail>
        <div class="calendar-detail__eyebrow">Selected day</div>
        <div class="calendar-detail__header">
          <div>
            <div class="calendar-detail__title" data-calendar-detail-title>Loading...</div>
            <div class="calendar-detail__meta" data-calendar-detail-meta>Choose a date to inspect the Hijri and Gregorian details.</div>
          </div>
          <div class="calendar-detail__badge" data-calendar-detail-badge>Regular day</div>
        </div>
        <p class="calendar-detail__note" data-calendar-detail-note>No special event listed for this date.</p>
      </div>

      <div class="card card--white" id="special-islamic-days" style="margin: 24px 0;">
        <div class="heading-row">
          <div>
            <div class="card__title">Special Islamic Days</div>
            <div class="card__meta">Major estimated dates listed inside the {year} dataset.</div>
          </div>
        </div>
        <div class="special-days" data-special-days set:html={initialSpecialDaysMarkup}></div>
      </div>

      <div class="card card--white" style="margin-top: 24px;">
        <div class="heading-row" style="margin-bottom: 12px;">
          <div>
            <div class="card__title">Browse calendar years</div>
            <div class="card__meta">Jump to upcoming Islamic calendar pages or the Ramadan year hub.</div>
          </div>
        </div>
        <div class="pill-row">
          <a class="chip" href="/calendar">All Islamic calendar pages</a>
          <a class="chip" href="/ramadhan">Ramadan pages</a>
          {ALL_CALENDAR_YEARS.map((itemYear) => (
            <a class="chip" href={`/islamic-calendar-${itemYear}`} aria-current={itemYear === year ? "page" : undefined}>
              {itemYear}
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid--2" style="margin-top: 24px;">
        <div class="card">
          <h2 class="card__title">What is the Islamic date today?</h2>
          <p class="muted">{calendarFaqItems[0].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">What is today in Hijri?</h2>
          <p class="muted">{calendarFaqItems[1].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">What is the Hijri date now?</h2>
          <p class="muted">{calendarFaqItems[2].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">What date is today in the Arabic calendar?</h2>
          <p class="muted">{calendarFaqItems[3].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">Islamic calendar {year}</h2>
          <p class="muted">{calendarFaqItems[4].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">When is Hajj {year}?</h2>
          <p class="muted">{calendarFaqItems[5].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">When is Eid al Fitr {year}?</h2>
          <p class="muted">{calendarFaqItems[6].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">When is Eid ul Fitr {year}?</h2>
          <p class="muted">{calendarFaqItems[7].answer}</p>
        </div>
        <div class="card">
          <h2 class="card__title">When is Muharram {year}?</h2>
          <p class="muted">{calendarFaqItems[8].answer}</p>
        </div>
      </div>
    </div>
  </section>
  <script define:vars={{ year, monthNames: MONTH_NAMES }}>
    const monthSelect = document.querySelector("[data-calendar-month]");
    const adjustSelect = document.querySelector("[data-calendar-adjustment]");
    const yearSelect = document.querySelector("[data-calendar-year]");
    const grid = document.querySelector("[data-calendar-grid]");
    const specialDays = document.querySelector("[data-special-days]");
    const title = document.querySelector("[data-calendar-title]");
    const todayHijri = document.querySelector("[data-calendar-today-hijri]");
    const detail = document.querySelector("[data-calendar-detail]");
    const detailTitle = document.querySelector("[data-calendar-detail-title]");
    const detailMeta = document.querySelector("[data-calendar-detail-meta]");
    const detailBadge = document.querySelector("[data-calendar-detail-badge]");
    const detailNote = document.querySelector("[data-calendar-detail-note]");
    const sourceNote = document.querySelector("[data-calendar-source]");

    const DATA_YEAR = year;
    const DATA_URL = `/data/islamic-calendar/${DATA_YEAR}.json`;
    const LIVE_API_BASE = "https://api.aladhan.com/v1/gToHCalendar";
    let calendarData = null;
    let calendarSource = "local";

    const weekDays = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

    const setTitle = (month, activeYear) => {
      if (title) title.textContent = `${monthNames[month - 1]} ${activeYear}`;
    };

    const cleanHoliday = (holiday) => holiday.replace(/\(.*?\)/g, "").trim();
    const normalizeHolidayKey = (holiday) =>
      String(holiday || "")
        .replace(/\(.*?\)/g, "")
        .toLowerCase()
        .replace(/&/g, " and ")
        .replace(/[^a-z0-9]+/g, " ")
        .trim();
    const allowedHolidayKeys = new Set([
      "lailat ul miraj",
      "lailat ul bara at",
      "1st day of ramadan",
      "lailat ul qadr",
      "eid ul fitr",
      "hajj",
      "arafa",
      "eid ul adha",
      "1st day of muharram",
      "ashura",
      "mawlid al nabi",
      "mawlid of the prophet",
      "mawlid birth al nabi",
      "beginning of the holy months",
      "end of the holy months",
      "treaty of hudaybiyya",
      "first time adhan was called in 622 ad"
    ]);
    const isIslamicHolidayEvent = (holiday) => allowedHolidayKeys.has(normalizeHolidayKey(holiday));

    const majorHolidayKeys = new Set([
      "1st day of ramadan",
      "lailat ul qadr",
      "eid ul fitr",
      "hajj",
      "arafa",
      "eid ul adha",
      "1st day of muharram",
      "ashura",
      "mawlid al nabi",
      "mawlid of the prophet",
      "mawlid birth al nabi"
    ]);
    const isMajorHoliday = (holiday) => majorHolidayKeys.has(normalizeHolidayKey(holiday));
    const normalizeHijriMonthName = (month) => {
      const normalized = String(month || "")
        .toLowerCase()
        .replace(/[^a-z]/g, "");
      const monthMap = {
        muharram: "Muharram",
        muarram: "Muharram",
        safar: "Safar",
        afar: "Safar",
        rabialawwal: "Rabi al-Awwal",
        rabialthani: "Rabi al-Thani",
        jumadaalawwal: "Jumada al-Awwal",
        jumadaalthani: "Jumada al-Thani",
        rajab: "Rajab",
        shaban: "Shaban",
        shaaban: "Shaban",
        ramadan: "Ramadan",
        shawwal: "Shawwal",
        dhualqidah: "Dhu al-Qidah",
        dhalqidah: "Dhu al-Qidah",
        dhalqadah: "Dhu al-Qidah",
        dhualhijjah: "Dhu al-Hijjah",
        dhalijjah: "Dhu al-Hijjah",
        dhalhijjah: "Dhu al-Hijjah"
      };
      return monthMap[normalized] || String(month || "").trim();
    };

    const formatHijriDate = (hijri, dayOverride = hijri?.day) => {
      if (!dayOverride || !hijri?.month?.en || !hijri?.year) return "";
      return `${dayOverride} ${normalizeHijriMonthName(hijri.month.en)} ${hijri.year}`;
    };

    const getDerivedHoliday = (hijri, dayOverride = hijri?.day) => {
      const day = Number(dayOverride);
      const month = normalizeHijriMonthName(hijri?.month?.en);
      if (month === "Muharram" && day === 1) return "1st day of Muharram";
      if (month === "Muharram" && day === 10) return "Ashura";
      if (month === "Ramadan" && day === 1) return "1st day of Ramadan";
      if (month === "Shawwal" && day === 1) return "Eid-ul-Fitr";
      if (month === "Dhu al-Hijjah" && day === 9) return "Arafa";
      if (month === "Dhu al-Hijjah" && day === 10) return "Eid-ul-Adha";
      if (month === "Rabi al-Awwal" && day === 12) return "Mawlid of the Prophet";
      return "";
    };

    const formatEventLabel = (holiday) => {
      const normalized = normalizeHolidayKey(holiday);
      const labelMap = {
        "1st day of ramadan": "1st Ramadan",
        "lailat ul qadr": "Laylat al Qadr",
        "eid ul fitr": "Eid ul Fitr",
        hajj: "Hajj",
        arafa: "Arafah",
        "eid ul adha": "Eid ul Adha",
        "1st day of muharram": "Islamic New Year",
        ashura: "10 Muharram",
        "mawlid al nabi": "Mawlid al Nabi",
        "mawlid of the prophet": "Mawlid al Nabi",
        "mawlid birth al nabi": "Mawlid al Nabi"
      };
      return labelMap[normalized] || cleanHoliday(holiday);
    };

    const getHolidayMap = (data) => {
      const map = new Map();
      data.forEach((day) => {
        const holiday = day.hijri?.holidays?.[0];
        if (!holiday || !isIslamicHolidayEvent(holiday)) return;
        const key = `${day.hijri.day}|${day.hijri.month.en}|${day.hijri.year}`;
        map.set(key, cleanHoliday(holiday));
      });
      return map;
    };

    const renderCalendar = (data, month, activeYear, adjustment = 0) => {
      if (!grid) return;
      const firstDate = new Date(activeYear, month - 1, 1);
      const startOffset = (firstDate.getDay() + 6) % 7;
      const blanks = Array.from({ length: startOffset });
      const today = new Date();
      const isCurrentMonth = today.getMonth() + 1 === month && today.getFullYear() === activeYear;
      const holidayMap = getHolidayMap(data);
      const seenHolidayLabels = new Set();

      const cells = [
        ...weekDays.map((day) => `<div class="calendar-cell calendar-cell--muted"><span class="calendar-cell__day">${day}</span></div>`),
        ...blanks.map(() => `<div class="calendar-cell calendar-cell--muted"></div>`),
        ...data.map((day) => {
          const adjustedHijriDay = Number(day.hijri.day) + adjustment;
          const holidayKey = `${adjustedHijriDay}|${day.hijri.month.en}|${day.hijri.year}`;
          const rawHoliday = holidayMap.get(holidayKey) || getDerivedHoliday(day.hijri, adjustedHijriDay);
          const label = rawHoliday ? formatEventLabel(rawHoliday) : "";
          const isToday = isCurrentMonth && Number(day.gregorian.day) === today.getDate();
          const labelKey = rawHoliday ? normalizeHolidayKey(rawHoliday) : "";
          const showLabel = label && !seenHolidayLabels.has(labelKey);
          if (showLabel) seenHolidayLabels.add(labelKey);

          const isMajor = isMajorHoliday(rawHoliday);
          const gregorianDate = new Date(activeYear, month - 1, Number(day.gregorian.day));
          const gregorianLong = new Intl.DateTimeFormat("en", {
            weekday: "long",
            month: "long",
            day: "numeric",
            year: "numeric"
          }).format(gregorianDate);
          const fullHijri = formatHijriDate(day.hijri, adjustedHijriDay);

          const classNames = [
            "calendar-cell",
            isToday && "calendar-cell--today",
            showLabel && "calendar-cell--highlight",
            isMajor && "calendar-cell--major"
          ].filter(Boolean).join(" ");

          return `
            <button
              class="${classNames}"
              type="button"
              data-calendar-day
              data-gregorian="${gregorianLong}"
              data-hijri="${fullHijri}"
              data-holiday="${rawHoliday}"
            >
              <div class="calendar-cell__top">
                <div class="calendar-cell__day-wrap">
                  <div class="calendar-cell__day">${Number(day.gregorian.day)}</div>
                  ${isToday ? '<span class="calendar-cell__today-label">Today</span>' : ""}
                </div>
              </div>
              <div class="calendar-cell__hijri">${fullHijri}</div>
              ${showLabel ? `<div class="calendar-cell__event">${label}</div>` : ""}
            </button>
          `;
        })
      ];

      grid.innerHTML = cells.join("");
      bindCalendarInteractions();
    };

    const formatSpecialTitle = (holiday) => {
      const titleMap = {
        "lailat ul miraj": "Shab e Meraj",
        "lailat ul bara at": "Shab e Barat",
        "1st day of ramadan": "1st Ramadan",
        "lailat ul qadr": "Laylat al Qadr",
        "eid ul fitr": "Eid ul Fitr",
        hajj: "Hajj",
        arafa: "Day of Arafah",
        "eid ul adha": "Eid ul Adha",
        "1st day of muharram": "1st Muharram (Islamic New Year)",
        ashura: "10 Muharram (Ashura)",
        "mawlid al nabi": "Mawlid al Nabi",
        "mawlid of the prophet": "Mawlid al Nabi",
        "mawlid birth al nabi": "Mawlid al Nabi",
        "beginning of the holy months": "Beginning of the holy months",
        "end of the holy months": "End of the holy months",
        "treaty of hudaybiyya": "Treaty of Hudaybiyya"
      };
      const normalized = normalizeHolidayKey(holiday);
      return titleMap[normalized] || String(holiday || "").replace(/[-_]+/g, " ").trim();
    };

    const setActiveCalendarDay = (button) => {
      if (!button || !detail || !detailTitle || !detailMeta || !detailBadge || !detailNote) return;
      grid?.querySelectorAll("[data-calendar-day].is-selected").forEach((item) => item.classList.remove("is-selected"));
      button.classList.add("is-selected");
      const gregorian = button.getAttribute("data-gregorian") || "--";
      const hijri = button.getAttribute("data-hijri") || "--";
      const holiday = button.getAttribute("data-holiday") || "";

      detailTitle.textContent = gregorian;
      detailMeta.textContent = hijri;
      detailBadge.textContent = holiday ? "Special day" : "Regular day";
      detailBadge.classList.toggle("is-special", Boolean(holiday));
      detailNote.textContent = holiday ? formatSpecialTitle(holiday) : "No special event listed for this date.";
    };

    const bindCalendarInteractions = () => {
      const buttons = Array.from(grid?.querySelectorAll("[data-calendar-day]") || []);
      if (!buttons.length) return;
      buttons.forEach((button) => {
        button.addEventListener("click", () => setActiveCalendarDay(button));
      });
      const preferred =
        buttons.find((button) => button.classList.contains("calendar-cell--today")) ||
        buttons.find((button) => button.classList.contains("calendar-cell--major")) ||
        buttons.find((button) => button.classList.contains("calendar-cell--highlight")) ||
        buttons[0];
      setActiveCalendarDay(preferred);
    };

    const renderSpecialDays = (months) => {
      if (!specialDays) return;
      const seen = new Set();
      const items = [];
      const now = new Date();
      const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

      Object.keys(months || {})
        .sort((a, b) => Number(a) - Number(b))
        .forEach((monthKey) => {
          const monthDays = Array.isArray(months?.[monthKey]) ? months[monthKey] : [];
          monthDays.forEach((day) => {
            const holidays = Array.isArray(day?.hijri?.holidays) ? day.hijri.holidays : [];
            const derivedHoliday = getDerivedHoliday(day.hijri);
            const calendarHolidays = derivedHoliday ? [derivedHoliday, ...holidays] : holidays;
            calendarHolidays.forEach((holiday) => {
              const label = String(holiday || "").replace(/\(.*?\)/g, "").trim();
              const key = normalizeHolidayKey(label);
              if (!key || seen.has(key) || !isIslamicHolidayEvent(label)) return;
              const gregorianDate = new Date(DATA_YEAR, Number(monthKey) - 1, Number(day?.gregorian?.day));
              if (Number.isNaN(gregorianDate.getTime())) return;
              if (gregorianDate < today) return;
              seen.add(key);
              items.push({
                title: formatSpecialTitle(label),
                gregorian: new Intl.DateTimeFormat("en", {
                  month: "long",
                  day: "2-digit",
                  year: "numeric"
                }).format(gregorianDate),
                month: new Intl.DateTimeFormat("en", { month: "short" }).format(gregorianDate),
                day: String(gregorianDate.getDate()).padStart(2, "0"),
                hijri: formatHijriDate(day.hijri)
              });
            });
          });
        });

      if (!items.length) {
        specialDays.innerHTML = `
          <div class="special-day special-day--empty">
            <div class="special-day__date">
              <span class="special-day__month">--</span>
              <span class="special-day__day">--</span>
            </div>
            <div class="special-day__body">
              <div class="special-day__title">No upcoming special dates found</div>
              <div class="special-day__meta">The dataset still contains the year, but all major dates have already passed.</div>
            </div>
            <div class="special-day__right">${DATA_YEAR}</div>
          </div>
        `;
        return;
      }

      specialDays.innerHTML = items.slice(0, 10).map((item) => `
        <div class="special-day">
          <div class="special-day__date">
            <span class="special-day__month">${item.month}</span>
            <span class="special-day__day">${item.day}</span>
          </div>
          <div class="special-day__body">
            <div class="special-day__title">${item.title}</div>
            <div class="special-day__meta">${item.hijri}</div>
          </div>
          <div class="special-day__right">${item.gregorian}</div>
        </div>
      `).join("");
    };

    const normalizeApiText = (value) => String(value || "").replace(/[^\x20-\x7E]/g, "").trim();

    const normalizeApiDay = (day) => ({
      gregorian: {
        day: normalizeApiText(day?.gregorian?.day)
      },
      hijri: {
        day: normalizeApiText(day?.hijri?.day),
        month: {
          en: normalizeApiText(day?.hijri?.month?.en)
        },
        year: normalizeApiText(day?.hijri?.year),
        holidays: Array.isArray(day?.hijri?.holidays)
          ? day.hijri.holidays.map(normalizeApiText).filter(Boolean)
          : []
      }
    });

    const fetchLiveCalendarData = async () => {
      const monthEntries = await Promise.all(
        Array.from({ length: 12 }, async (_, index) => {
          const month = index + 1;
          const response = await fetch(`${LIVE_API_BASE}/${month}/${DATA_YEAR}`, {
            cache: "no-store"
          });
          if (!response.ok) throw new Error(`Unable to refresh Hijri calendar for ${DATA_YEAR}-${month}.`);
          const payload = await response.json();
          const days = Array.isArray(payload?.data) ? payload.data.map(normalizeApiDay) : [];
          if (!days.length) throw new Error(`Empty Hijri calendar response for ${DATA_YEAR}-${month}.`);
          return [String(month), days];
        })
      );
      return Object.fromEntries(monthEntries);
    };

    const setCalendarSourceText = () => {
      if (!sourceNote) return;
      const now = new Date();
      const refreshedAt = new Intl.DateTimeFormat("en", {
        month: "short",
        day: "numeric",
        year: "numeric",
        hour: "numeric",
        minute: "2-digit"
      }).format(now);
      sourceNote.textContent =
        calendarSource === "live"
          ? `Calendar source: live AlAdhan Hijri API, refreshed ${refreshedAt}. Dates remain estimates and can shift with local moon sighting.`
          : "Calendar source: local fallback data. Dates remain estimates and can shift with local moon sighting.";
    };

    const loadCalendarData = async () => {
      if (calendarData) return;
      try {
        calendarData = await fetchLiveCalendarData();
        calendarSource = "live";
        setCalendarSourceText();
        return;
      } catch (error) {
        console.warn("Live calendar refresh failed; using local fallback.", error);
      }

      try {
        const response = await fetch(DATA_URL);
        if (!response.ok) throw new Error("Failed to load calendar.");
        const payload = await response.json();
        calendarData = payload?.months || {};
        calendarSource = "local";
        setCalendarSourceText();
      } catch (error) {
        console.error("Calendar load error:", error);
        calendarData = null;
        if (grid) {
          grid.innerHTML = `<div class="card" style="grid-column: 1 / -1;">Unable to load calendar data.</div>`;
        }
      }
    };

    const formatHijri = (hijri) => {
      if (!hijri?.day || !hijri?.month?.en || !hijri?.year) return null;
      return `${hijri.day} ${normalizeHijriMonthName(hijri.month.en)}, ${hijri.year}`;
    };

    const setTodayHijriText = async () => {
      if (!todayHijri) return;
      const now = new Date();
      const dataYear = now.getFullYear();
      if (dataYear !== DATA_YEAR) return;
      try {
        const response = await fetch(`/data/islamic-calendar/${dataYear}.json`);
        if (response.ok) {
          const payload = await response.json();
          const monthData = payload?.months?.[String(now.getMonth() + 1)];
          if (Array.isArray(monthData)) {
            const matched = monthData.find((day) => Number(day?.gregorian?.day) === now.getDate());
            const formatted = formatHijri(matched?.hijri);
            if (formatted) {
              todayHijri.textContent = formatted;
            }
          }
        }
      } catch {
        // Keep server rendered text.
      }
    };

    const renderFromData = (month, activeYear, adjustment) => {
      setTitle(month, activeYear);
      const data = Array.isArray(calendarData?.[String(month)]) ? calendarData[String(month)] : [];
      if (!data.length) {
        if (grid) {
          grid.innerHTML = `<div class="card" style="grid-column: 1 / -1;">Calendar data unavailable for this month.</div>`;
        }
        return;
      }
      renderCalendar(data, month, activeYear, adjustment);
    };

    const setDefaults = () => {
      const requestedMonth = Number(new URLSearchParams(window.location.search).get("month"));
      const defaultMonth = DATA_YEAR === new Date().getFullYear() ? new Date().getMonth() + 1 : 1;
      const initialMonth = requestedMonth >= 1 && requestedMonth <= 12 ? requestedMonth : defaultMonth;
      if (monthSelect) monthSelect.value = String(initialMonth);
      if (adjustSelect) adjustSelect.value = "0";
    };

    const handleChange = () => {
      const month = Number(monthSelect?.value) || 1;
      const adjustment = Number(adjustSelect?.value) || 0;
      loadCalendarData().then(() => {
        if (!calendarData) return;
        renderFromData(month, DATA_YEAR, adjustment);
        renderSpecialDays(calendarData);
      });
    };

    const handleNav = (dir) => {
      let month = Number(monthSelect?.value) || 1;
      month += dir;
      if (month < 1) month = 1;
      if (month > 12) month = 12;
      if (monthSelect) {
        monthSelect.value = String(month);
        handleChange();
      }
    };

    const init = () => {
      setDefaults();
      setTodayHijriText();
      handleChange();
      monthSelect?.addEventListener("change", handleChange);
      adjustSelect?.addEventListener("change", handleChange);
      yearSelect?.addEventListener("change", () => {
        const month = Number(monthSelect?.value) || 1;
        window.location.href = `/islamic-calendar-${yearSelect.value}?month=${month}`;
      });
      document.getElementById("prev-month")?.addEventListener("click", () => handleNav(-1));
      document.getElementById("next-month")?.addEventListener("click", () => handleNav(1));
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  </script>
</BaseLayout>
