---
<footer class="footer">
  <div class="container footer__grid">
    <div>
      <div class="footer__title">About TaqwaPath</div>
      <p class="muted">
        TaqwaPath is a calm, modern Islamic utility designed for daily worship, learning,
        and reflection. Data is provided for convenience and may vary by method or region.
      </p>
      <p class="muted" style="margin-top: 10px;">
        Maintained by Talha Zahid. Islamic dates, prayer times, and zakat estimates are reviewed as practical references and should be confirmed with local authorities or qualified scholars when needed.
      </p>
      <div style="margin-top: 12px;">
        <ul class="footer__links">
          <li><a href="/about">About</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
    <div>
      <div class="footer__title">Explore</div>
      <ul class="footer__links">
        <li><a href="/hadith">Hadith library</a></li>
        <li><a href="/quran-online">Online Quran</a></li>
        <li><a href="/calendar">Islamic Calendar</a></li>
        <li><a href="/ramadhan">Ramadan</a></li>
        <li><a href="/zakat-calculator">Zakat Calculator</a></li>
        <li><a href="/salah-namaz-timings">Salah Timings</a></li>
      </ul>
    </div>
    <div>
      <div class="footer__title">Stay Connected</div>
      <ul class="footer__links">
        <li>
          Contact: <a href="mailto:info@taqwapath.com">Email Us</a>
        </li>
        <li class="footer__donate">
          <form action="https://www.paypal.com/donate" method="post" target="_top">
            <input type="hidden" name="hosted_button_id" value="RCB59YCUHYHSQ" />
            <input
              type="image"
              src="https://www.paypalobjects.com/en_US/i/btn/btn_donate_LG.gif"
              border="0"
              name="submit"
              title="PayPal - The safer, easier way to pay online!"
              alt="Donate with PayPal button"
            />
          </form>
          <small class="footer__note">
            Zakat not accepted. Support us with a general donation to keep the site running.
          </small>
        </li>
      </ul>
    </div>
    <div>
      <div class="footer__title">Download The APP</div>
      <div class="footer__store">
        <a
          href="https://play.google.com/store/apps/details?id=com.taqwapath.taqwapath_mobile"
          target="_blank"
          rel="noreferrer"
        >
          <img
            class="footer__store-badge"
            src="/assets/playstore-badge.svg"
            alt="Get it on Google Play"
            width="180"
            height="54"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </div>
</footer>
