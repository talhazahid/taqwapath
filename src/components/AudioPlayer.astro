<div class="audio-player-shell" transition:persist>
  <div class="audio-player" data-player data-active="false">
    <div class="audio-player__controls">
      <button class="audio-btn" data-action="prev" aria-label="Previous">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M7 6v12M19 6l-8 6 8 6V6z" stroke="currentColor" stroke-width="1.6" />
        </svg>
      </button>
      <button class="audio-btn audio-btn--main" data-action="toggle" data-state="paused" aria-label="Play">
        <span data-icon="play">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M7 5l12 7-12 7V5z" fill="currentColor" />
          </svg>
        </span>
        <span data-icon="pause">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M7 5h4v14H7zM13 5h4v14h-4z" fill="currentColor" />
          </svg>
        </span>
      </button>
      <button class="audio-btn" data-action="next" aria-label="Next">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M17 6v12M5 6l8 6-8 6V6z" stroke="currentColor" stroke-width="1.6" />
        </svg>
      </button>
    </div>
    <div class="audio-player__meta">
      <div class="audio-player__title" data-track-title>Ready to play</div>
      <input
        class="audio-progress"
        type="range"
        min="0"
        max="0"
        value="0"
        step="1"
        aria-label="Seek"
        data-progress
      />
    </div>
    <div class="audio-player__right">
      <div class="audio-player__time" data-track-time>0:00 / 0:00</div>
      <button class="audio-btn audio-btn--labeled" data-action="shuffle" aria-label="Shuffle">
        <span class="audio-btn__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path
              d="M16 3l5 5-5 5M4 4l5 5m6 6 7 7M4 20l5-5m7 5h5v-5"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </span>
        <span class="audio-btn__label">Shuffle</span>
      </button>
      <button class="audio-btn audio-btn--labeled" data-action="repeat" aria-label="Repeat">
        <span class="audio-btn__icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path
              d="M17 2l4 4-4 4M3 11V9a4 4 0 0 1 4-4h14M7 22l-4-4 4-4M21 13v2a4 4 0 0 1-4 4H3"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </span>
        <span class="audio-btn__label">Repeat</span>
      </button>
      <button class="audio-btn audio-btn--close" data-action="close" aria-label="Close player">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M6 6l12 12M18 6l-12 12"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
          />
        </svg>
      </button>
    </div>
  </div>
  <audio data-audio preload="metadata"></audio>
</div>

<script>
  (() => {
    if (window.__taqwaPlayerInit) return;
    window.__taqwaPlayerInit = true;

  const STORAGE_KEY = "taqwapath.player";
  const DISMISS_KEY = "taqwapath.player.dismissed";
  const player = document.querySelector("[data-player]");
  const audio = document.querySelector("[data-audio]");
  const titleEl = player?.querySelector("[data-track-title]");
  const timeEl = player?.querySelector("[data-track-time]");
  const progress = player?.querySelector("[data-progress]");
  const toggleBtn = player?.querySelector('[data-action="toggle"]');
  const prevBtn = player?.querySelector('[data-action="prev"]');
  const nextBtn = player?.querySelector('[data-action="next"]');
  const shuffleBtn = player?.querySelector('[data-action="shuffle"]');
  const repeatBtn = player?.querySelector('[data-action="repeat"]');
  const closeBtn = player?.querySelector('[data-action="close"]');

  let tracks = [];
  let currentIndex = -1;
  let shuffleEnabled = false;
  let repeatOneEnabled = false;

  const formatTime = (seconds) => {
    if (!Number.isFinite(seconds)) return "0:00";
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, "0")}`;
  };

  const setToggleState = (isPlaying) => {
    if (!toggleBtn) return;
    toggleBtn.dataset.state = isPlaying ? "playing" : "paused";
    toggleBtn.setAttribute("aria-label", isPlaying ? "Pause" : "Play");
  };

  const setActionState = (button, isActive, label) => {
    if (!button) return;
    button.classList.toggle("is-active", isActive);
    button.setAttribute("aria-pressed", isActive ? "true" : "false");
    if (label) {
      button.setAttribute("aria-label", isActive ? `${label} on` : `${label} off`);
    }
  };

  const isDismissed = () => localStorage.getItem(DISMISS_KEY) === "true";

  const setDismissed = (value) => {
    if (value) {
      localStorage.setItem(DISMISS_KEY, "true");
    } else {
      localStorage.removeItem(DISMISS_KEY);
    }
  };

  const updateTime = () => {
    if (!timeEl || !audio) return;
    const current = formatTime(audio.currentTime);
    const total = formatTime(audio.duration);
    timeEl.textContent = `${current} / ${total}`;
    if (progress) {
      const duration = Number.isFinite(audio.duration) ? audio.duration : 0;
      progress.max = duration ? String(duration) : "0";
      progress.value = String(audio.currentTime || 0);
      const percent = duration ? (audio.currentTime / duration) * 100 : 0;
      progress.style.setProperty("--progress", `${percent}%`);
    }
  };

  const saveState = () => {
    if (!audio || currentIndex < 0) return;
    const track = tracks[currentIndex];
    if (!track) return;
    const payload = {
      ...track,
      time: audio.currentTime || 0,
      index: currentIndex
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
  };

  const updatePlayButtons = () => {
    const allButtons = document.querySelectorAll(".js-play-track");
    allButtons.forEach((btn, idx) => {
      const btnText = btn.querySelector(".play-btn-text");
      if (!btnText) return;
      if (idx === currentIndex && audio && !audio.paused) {
        btnText.textContent = "Pause";
      } else {
        btnText.textContent = "Play";
      }
    });
  };

  const setTrack = (track, index, autoplay = true, showPlayer = true) => {
    if (!track || !audio || !player) return;
    audio.src = track.src;
    audio.dataset.fallbackSrc = track.fallbackSrc || "";
    audio.dataset.fallbackTried = "false";
    currentIndex = index;
    if (titleEl) titleEl.textContent = track.title;
    if (showPlayer) {
      setDismissed(false);
      player.dataset.active = "true";
    } else {
      player.dataset.active = "false";
    }
    if (autoplay) {
      audio.play();
    }
    setToggleState(autoplay);
    updateTime();
    saveState();
    updatePlayButtons();
  };

  const getRandomIndex = (excludeIndex) => {
    const total = tracks.length;
    if (total === 0) return -1;
    if (total === 1) return 0;
    if (!Number.isFinite(excludeIndex) || excludeIndex < 0 || excludeIndex >= total) {
      return Math.floor(Math.random() * total);
    }
    let nextIndex = excludeIndex;
    while (nextIndex === excludeIndex) {
      nextIndex = Math.floor(Math.random() * total);
    }
    return nextIndex;
  };

  const getNextIndex = () => {
    if (tracks.length === 0) return -1;
    if (shuffleEnabled) return getRandomIndex(currentIndex);
    if (currentIndex < 0 || currentIndex >= tracks.length - 1) return 0;
    return currentIndex + 1;
  };

  const getPrevIndex = () => {
    if (tracks.length === 0) return -1;
    if (shuffleEnabled) return getRandomIndex(currentIndex);
    if (currentIndex <= 0) return tracks.length - 1;
    return currentIndex - 1;
  };

  const collectTracks = () => {
    const buttons = Array.from(document.querySelectorAll(".js-play-track"));
    tracks = buttons.map((btn, index) => {
      btn.dataset.trackIndex = String(index);
      return {
        src: btn.dataset.trackSrc,
        fallbackSrc: btn.dataset.trackFallbackSrc || "",
        title: btn.dataset.trackTitle || "Untitled",
        index
      };
    });
  };

  const playByIndex = (index) => {
    const track = tracks[index];
    if (!track) return;
    setTrack(track, index, true);
  };

  collectTracks();

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) return;
    const button = event.target.closest(".js-play-track");
    if (!button) return;
    collectTracks();
    const index = Number(button.dataset.trackIndex);

    // If clicking the same track that's playing, pause it
    if (index === currentIndex && audio && !audio.paused) {
      audio.pause();
      setToggleState(false);
      updatePlayButtons();
    } else {
      playByIndex(index);
    }
  });

  toggleBtn?.addEventListener("click", () => {
    if (!audio || currentIndex < 0) return;
    if (audio.paused) {
      audio.play();
      setToggleState(true);
      updatePlayButtons();
    } else {
      audio.pause();
      setToggleState(false);
      updatePlayButtons();
    }
  });

  prevBtn?.addEventListener("click", () => {
    if (tracks.length === 0) return;
    const nextIndex = getPrevIndex();
    if (nextIndex < 0) return;
    playByIndex(nextIndex);
  });

  nextBtn?.addEventListener("click", () => {
    if (tracks.length === 0) return;
    const nextIndex = getNextIndex();
    if (nextIndex < 0) return;
    playByIndex(nextIndex);
  });

  audio?.addEventListener("timeupdate", () => {
    updateTime();
    saveState();
  });

  audio?.addEventListener("loadedmetadata", updateTime);
  audio?.addEventListener("play", () => {
    setToggleState(true);
    updatePlayButtons();
  });
  audio?.addEventListener("pause", () => {
    setToggleState(false);
    updatePlayButtons();
  });
  audio?.addEventListener("error", () => {
    if (!audio) return;
    const fallback = audio.dataset.fallbackSrc || "";
    if (!fallback) return;
    if (audio.dataset.fallbackTried === "true") return;
    audio.dataset.fallbackTried = "true";
    audio.src = fallback;
    audio.play();
  });

  audio?.addEventListener("ended", () => {
    if (tracks.length === 0) return;
    if (repeatOneEnabled && audio) {
      audio.currentTime = 0;
      audio.play();
      setToggleState(true);
      updatePlayButtons();
      return;
    }
    const nextIndex = getNextIndex();
    if (nextIndex < 0) return;
    playByIndex(nextIndex);
  });

  progress?.addEventListener("input", () => {
    if (!audio) return;
    audio.currentTime = Number(progress.value || 0);
    updateTime();
  });

  setActionState(shuffleBtn, shuffleEnabled, "Shuffle");
  setActionState(repeatBtn, repeatOneEnabled, "Repeat");

  shuffleBtn?.addEventListener("click", () => {
    shuffleEnabled = !shuffleEnabled;
    setActionState(shuffleBtn, shuffleEnabled, "Shuffle");
  });

  repeatBtn?.addEventListener("click", () => {
    repeatOneEnabled = !repeatOneEnabled;
    setActionState(repeatBtn, repeatOneEnabled, "Repeat");
  });

  closeBtn?.addEventListener("click", () => {
    if (!player) return;
    setDismissed(true);
    player.dataset.active = "false";
    if (audio) {
      audio.pause();
      setToggleState(false);
      updatePlayButtons();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (isDismissed()) return;
    const target = event.target;
    if (target instanceof HTMLElement) {
      const tag = target.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA" || target.isContentEditable) {
        return;
      }
    }
    if (event.code === "Space") {
      event.preventDefault();
      toggleBtn?.click();
    }
    if (event.code === "ArrowRight" && audio) {
      audio.currentTime = Math.min(audio.currentTime + 10, audio.duration || audio.currentTime + 10);
    }
    if (event.code === "ArrowLeft" && audio) {
      audio.currentTime = Math.max(audio.currentTime - 10, 0);
    }
  });

  const restore = () => {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (!saved) return;
    try {
      const data = JSON.parse(saved);
      if (!data?.src) return;
      const dismissed = isDismissed();
      setTrack(
        { src: data.src, fallbackSrc: data.fallbackSrc || "", title: data.title },
        data.index ?? 0,
        false,
        !dismissed
      );
      if (audio) {
        audio.currentTime = data.time || 0;
        updateTime();
      }
    } catch {
      localStorage.removeItem(STORAGE_KEY);
    }
  };

  restore();
  })();
</script>
