---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Privacy Policy - TaqwaPath"
  description="TaqwaPath privacy policy: we do not collect personal data."
  showDateStrip={false}
>
  <section class="section">
    <div class="container">
      <span class="pill">Privacy</span>
      <h1 class="section-title">Privacy Policy</h1>
      <p class="section-lead">
        We respect your privacy. TaqwaPath does not collect, store, or sell personal data.
      </p>

      <div class="grid grid--2">
        <div class="card">
          <div class="card__title">Data collection</div>
          <p class="muted">
            We do not ask for personal information and we do not store user data on our servers.
          </p>
        </div>

        <div class="card">
          <div class="card__title">Cookies & tracking</div>
          <p class="muted">We do not use cookies or tracking scripts.</p>
        </div>

        <div class="card">
          <div class="card__title">Third-party services</div>
          <p class="muted">
            If you choose to use external links (for example, donations), those services handle data
            under their own policies.
          </p>
        </div>

        <div class="card">
          <div class="card__title">Questions</div>
          <p class="muted">
            Contact us at <a href="mailto:info@taqwapath.com">info@taqwapath.com</a>.
          </p>
          <div class="tag" style="margin-top: 8px;">Effective date: February 6, 2026</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
