---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import HadithShareDialog from "../../../../components/HadithShareDialog.astro";
import { fetchHadithBooks, fetchHadiths, fetchChapters } from "../../../../lib/hadithApi.js";

export async function getStaticPaths() {
  const books = await fetchHadithBooks();
  const paths = [];

  for (const book of books) {
    const chapters = await fetchChapters(book.slug);
    const allHadiths = await fetchHadiths(book.slug, `1-${book.count || 10000}`, book.title);

    for (const chapter of chapters) {
      // Filter hadiths for this chapter (convert both to numbers for comparison)
      const chapterHadiths = allHadiths.filter(h => Number(h.chapter) === Number(chapter.id));

      paths.push({
        params: {
          bookSlug: book.slug,
          chapterId: chapter.id.toString()
        },
        props: {
          book,
          chapter,
          hadiths: chapterHadiths
        }
      });
    }
  }

  return paths;
}

const { book, chapter, hadiths } = Astro.props;

const normalizeReference = (reference) => {
  if (!reference) return null;
  if (typeof reference === "string") return { primary: reference };
  return {
    ...reference,
    primary: reference.primary || reference.reference || reference.main
  };
};

const buildChapterMeta = (entry) => {
  if (!entry) return null;
  const title = entry.subChapterTitle || entry.chapterTitle || "";
  const arabic = entry.subChapterTitleArabic || entry.chapterTitleArabic || "";
  const number = entry.subChapter ?? entry.chapter;
  if (!title && !arabic) return null;
  return { number, title, arabic };
};

const formatChapterMeta = (meta) => {
  if (!meta) return "";
  const prefix = meta.number ? `Chapter ${meta.number}: ` : "Chapter: ";
  const main = meta.title || meta.arabic || "";
  const suffix = meta.title && meta.arabic ? ` - ${meta.arabic}` : "";
  return `${prefix}${main}${suffix}`;
};

const buildLocalReferenceLink = (number) => {
  if (!book?.slug || number === undefined || number === null) return "";
  return `/hadees/${book.slug}-${number}`;
};

const buildReferenceItems = (reference, number) => {
  const items = [];
  if (reference?.primary) {
    const localLink = buildLocalReferenceLink(number);
    items.push({ label: "Reference", value: reference.primary, link: localLink || undefined });
  }
  if (reference?.inBook) items.push({ label: "In-book reference", value: reference.inBook });
  if (reference?.uscMsa) items.push({ label: "USC-MSA web (English) reference", value: reference.uscMsa });
  return items;
};

const normalizeTranslation = (entry) => {
  if (!entry) return null;
  if (typeof entry === "string") return { text: entry };
  return {
    sanad: entry.sanad || "",
    text: entry.text || ""
  };
};

const normalizedHadiths = (Array.isArray(hadiths) ? hadiths : []).map((hadith) => {
  const reference = normalizeReference(hadith.reference);
  const englishText = typeof hadith.text === 'object'
    ? (hadith.text.text || hadith.text)
    : (hadith.text || "");
  const narrator = hadith.narrator || (typeof hadith.text === 'object'
    ? (hadith.text.narrator || "")
    : "");
  const translations = hadith.translations || {};
  const urdu = normalizeTranslation(translations.urdu);
  const bangla = normalizeTranslation(translations.bangla);

  return {
    ...hadith,
    arab: hadith.arab || "",
    text: englishText,
    narrator: narrator,
    translations: {
      urdu,
      bangla
    },
    reference,
    referenceItems: buildReferenceItems(reference, hadith.number),
    chapterMeta: buildChapterMeta(hadith)
  };
});

const hasUrdu = normalizedHadiths.some((hadith) => hadith.translations.urdu?.text);
const hasBangla = normalizedHadiths.some((hadith) => hadith.translations.bangla?.text);
---
<BaseLayout
  title={`${chapter.title} Hadiths - ${book.title} - TaqwaPath`}
  description={`Chapter ${chapter.id} from ${book.title} with hadith text, references, and sharing tools.`}
>
  <section class="section">
    <div class="container">
      <div class="chapter-layout" data-language-root data-active-lang="english">
        <aside class="language-panel" data-language-switcher>
          <div class="language-panel__title">Language</div>
          <label class="language-option">
            <input type="radio" name="chapter-language" value="english" checked />
            <span>English</span>
          </label>
          {hasUrdu ? (
            <label class="language-option">
              <input type="radio" name="chapter-language" value="urdu" />
              <span>Urdu</span>
            </label>
          ) : null}
          {hasBangla ? (
            <label class="language-option">
              <input type="radio" name="chapter-language" value="bangla" />
              <span>Bangla</span>
            </label>
          ) : null}
        </aside>

        <div class="chapter-content">
          <div class="heading-row">
            <div>
              <span class="pill">Chapter {chapter.id}</span>
              <h1 class="section-title">{chapter.title}</h1>
            </div>
            {chapter.titleArabic ? (
              <p class="heading-row__arabic arabic-text">{chapter.titleArabic}</p>
            ) : null}
          </div>
          <p class="section-lead">
            From {book.title} - {hadiths.length} hadiths in this chapter
          </p>

          <div style="display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
            <a class="btn btn--secondary" href={`/hadees/${book.slug}/chapters`}>All Chapters</a>
            <a class="btn btn--ghost" href={`/hadees/${book.slug}`}>View Book</a>
          </div>

          <div class="list">
            {normalizedHadiths.length ? (
              normalizedHadiths.map((hadith, index) => (
                <article
                  class={`card anim-fade-up anim-delay-${(index % 3) + 1}`}
                  data-hadith-number={hadith.number}
                  data-share-url={`/hadees/${book.slug}-${hadith.number}`}
                >
                  <div class="card__title">Hadith {hadith.number}</div>
                  {hadith.chapterMeta ? (
                    <div class="card__meta" style="margin-bottom: 12px;">
                      {formatChapterMeta(hadith.chapterMeta)}
                    </div>
                  ) : null}
                  {hadith.arab ? (
                    <p class="hadith-arabic arabic-text" style="font-size: 1.25rem; line-height: 2; margin-bottom: 16px; direction: rtl; text-align: right;">
                      {hadith.arab}
                    </p>
                  ) : null}
                  <div class="translation-block" data-lang="english">
                    {hadith.narrator ? (
                      <p class="hadith-narrator" style="margin-bottom: 8px;"><strong>{hadith.narrator}</strong></p>
                    ) : null}
                    <p class="hadith-english muted" style="margin-bottom: 16px;">{hadith.text || "Translation unavailable."}</p>
                  </div>
                  <div
                    class={`translation-block translation-block--urdu ${hadith.translations.urdu?.text ? "" : "translation-block--fallback"}`}
                    data-lang="urdu"
                  >
                    {hadith.translations.urdu?.text ? (
                      <>
                        {hadith.translations.urdu?.sanad ? (
                          <p class="translation-sanad translation-sanad--urdu">{hadith.translations.urdu.sanad}</p>
                        ) : null}
                        <p class="translation-text translation-text--urdu">{hadith.translations.urdu.text}</p>
                      </>
                    ) : (
                      <>
                        {hadith.narrator ? (
                          <p class="hadith-narrator" style="margin-bottom: 8px;"><strong>{hadith.narrator}</strong></p>
                        ) : null}
                        <p class="translation-text muted">{hadith.text}</p>
                      </>
                    )}
                  </div>
                  <div
                    class={`translation-block translation-block--bangla ${hadith.translations.bangla?.text ? "" : "translation-block--fallback"}`}
                    data-lang="bangla"
                  >
                    {hadith.translations.bangla?.text ? (
                      <>
                        {hadith.translations.bangla?.sanad ? (
                          <p class="translation-sanad">{hadith.translations.bangla.sanad}</p>
                        ) : null}
                        <p class="translation-text">{hadith.translations.bangla.text}</p>
                      </>
                    ) : (
                      <>
                        {hadith.narrator ? (
                          <p class="hadith-narrator" style="margin-bottom: 8px;"><strong>{hadith.narrator}</strong></p>
                        ) : null}
                        <p class="translation-text muted">{hadith.text}</p>
                      </>
                    )}
                  </div>
                  {hadith.referenceItems.length ? (
                    <div class="hadith-reference reference-block">
                      {hadith.referenceItems.map((item) => (
                        <div class="reference-row">
                          <span class="reference-label">{item.label}</span>
                          <span class="reference-value">
                            {item.link ? (
                              <a href={item.link} target="_blank" rel="noreferrer">
                                {item.value}
                              </a>
                            ) : (
                              item.value
                            )}
                          </span>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="hadith-reference card__meta">Reference unavailable.</div>
                  )}
                  <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px;">
                    <button class="btn btn--secondary copy-hadith-btn">Copy</button>
                    <button class="btn btn--ghost" type="button" data-share-trigger>Share</button>
                  </div>
                </article>
              ))
            ) : (
              <div class="card">
                <strong>No hadiths available.</strong>
                <p class="muted">This chapter may be empty or being processed.</p>
              </div>
            )}
          </div>

          <div class="card" style="margin-top: 24px;">
            <strong>Chapter Navigation</strong>
            <div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap;">
              <a class="btn btn--secondary" href={`/hadees/${book.slug}/chapters`}>Back to All Chapters</a>
              <a class="btn btn--ghost" href={`/hadees/${book.slug}`}>View All Hadiths</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <HadithShareDialog />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const languageRoot = document.querySelector('[data-language-root]');
    const languageInputs = document.querySelectorAll('[data-language-switcher] input[type="radio"]');
    const copyButtons = document.querySelectorAll('.copy-hadith-btn');
    const getActiveLang = () => languageRoot?.dataset.activeLang || 'english';

    languageInputs.forEach((input) => {
      input.addEventListener('change', () => {
        if (!languageRoot) return;
        languageRoot.dataset.activeLang = input.value;
      });
    });

    copyButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const article = button.closest('article');
        const arabicText = article.querySelector('.hadith-arabic')?.textContent.trim() || '';
        const activeLang = getActiveLang();
        const translationBlock = article.querySelector(`.translation-block[data-lang="${activeLang}"]`);
        const translationText = translationBlock?.textContent.trim() || '';
        const reference = article.querySelector('.hadith-reference')?.textContent.trim() || '';

        // Build the formatted text
        let textToCopy = '';
        if (arabicText) {
          textToCopy += arabicText + '\n\n';
        }
        if (translationText) {
          textToCopy += translationText + '\n\n';
        }
        if (reference) {
          textToCopy += reference;
        }

        try {
          await navigator.clipboard.writeText(textToCopy.trim());
          const originalText = button.textContent;
          button.textContent = 'Copied!';
          button.style.background = 'var(--color-success, #22c55e)';

          setTimeout(() => {
            button.textContent = originalText;
            button.style.background = '';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
          button.textContent = 'Failed';
          setTimeout(() => {
            button.textContent = 'Copy';
          }, 2000);
        }
      });
    });
  });
</script>
