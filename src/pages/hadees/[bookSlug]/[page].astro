---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HadithShareDialog from "../../../components/HadithShareDialog.astro";
import { fetchHadithBooks, fetchHadiths } from "../../../lib/hadithApi.js";

export async function getStaticPaths() {
  const books = await fetchHadithBooks();
  const paths = [];

  for (const book of books) {
    // Fetch all hadiths for the book
    const allHadiths = await fetchHadiths(book.slug, `1-${book.count || 10000}`, book.title);
    const HADITHS_PER_PAGE = 200;
    const totalPages = Math.ceil(allHadiths.length / HADITHS_PER_PAGE);

    // Create pages for page 2 and onwards
    for (let page = 2; page <= totalPages; page++) {
      const start = (page - 1) * HADITHS_PER_PAGE;
      const end = start + HADITHS_PER_PAGE;
      const hadiths = allHadiths.slice(start, end);

      paths.push({
        params: { bookSlug: book.slug, page: page.toString() },
        props: {
          book,
          hadiths,
          currentPage: page,
          totalPages,
          totalHadiths: allHadiths.length
        }
      });
    }
  }

  return paths;
}

const { book, hadiths, currentPage, totalPages, totalHadiths } = Astro.props;

const normalizeReference = (reference) => {
  if (!reference) return null;
  if (typeof reference === "string") return { primary: reference };
  return {
    ...reference,
    primary: reference.primary || reference.reference || reference.main
  };
};

const buildChapterMeta = (entry) => {
  if (!entry) return null;
  const title = entry.subChapterTitle || entry.chapterTitle || "";
  const arabic = entry.subChapterTitleArabic || entry.chapterTitleArabic || "";
  const number = entry.subChapter ?? entry.chapter;
  if (!title && !arabic) return null;
  return { number, title, arabic };
};

const formatChapterMeta = (meta) => {
  if (!meta) return "";
  const prefix = meta.number ? `Chapter ${meta.number}: ` : "Chapter: ";
  const main = meta.title || meta.arabic || "";
  const suffix = meta.title && meta.arabic ? ` - ${meta.arabic}` : "";
  return `${prefix}${main}${suffix}`;
};

const buildLocalReferenceLink = (number) => {
  if (!book?.slug || number === undefined || number === null) return "";
  return `/hadees/${book.slug}-${number}`;
};

const buildReferenceItems = (reference, number) => {
  const items = [];
  if (reference?.primary) {
    const localLink = buildLocalReferenceLink(number);
    items.push({ label: "Reference", value: reference.primary, link: localLink || undefined });
  }
  if (reference?.inBook) items.push({ label: "In-book reference", value: reference.inBook });
  if (reference?.uscMsa) items.push({ label: "USC-MSA web (English) reference", value: reference.uscMsa });
  return items;
};

const normalizedHadiths = (Array.isArray(hadiths) ? hadiths : []).map((hadith) => {
  const reference = normalizeReference(hadith.reference);
  // Handle text that might be an object with narrator and text
  const englishText = typeof hadith.text === 'object'
    ? (hadith.text.text || hadith.text)
    : (hadith.text || "");
  const narrator = hadith.narrator || (typeof hadith.text === 'object'
    ? (hadith.text.narrator || "")
    : "");

  return {
    ...hadith,
    arab: hadith.arab || "",
    text: englishText,
    narrator: narrator,
    reference,
    referenceItems: buildReferenceItems(reference, hadith.number),
    chapterMeta: buildChapterMeta(hadith)
  };
});
---
<BaseLayout
  title={`${book.title} Hadiths - Page ${currentPage} - TaqwaPath`}
  description={`Read ${book.title} hadith page ${currentPage} with Arabic and English text, references, and sharing.`}
>
  <section class="section">
    <div class="container">
      <div class="heading-row">
        <div>
          <span class="pill">Hadith book - Page {currentPage}</span>
          <h1 class="section-title">{book.title}</h1>
        </div>
        {book.arabicTitle ? (
          <p class="heading-row__arabic arabic-text">{book.arabicTitle}</p>
        ) : null}
      </div>
      <p class="section-lead">
        {book.summary} Use the tools below to search, filter, and share reference-ready snippets.
      </p>

      <div style="display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
        <a class="btn btn--primary" href={`/hadees/${book.slug}/chapters`}>Browse by Chapter</a>
      </div>

      <div class="grid grid--3" style="margin-bottom: 24px;">
        <div class="card">
          <div class="card__title">Search within book</div>
          <input class="input" placeholder="Search by keyword or hadith number" />
        </div>
        <div class="card">
          <div class="card__title">Sort</div>
          <select class="select">
            <option>Default order</option>
            <option>Shortest</option>
            <option>Longest</option>
            <option>By chapter</option>
          </select>
        </div>
        <div class="card">
          <div class="card__title">Filter</div>
          <select class="select">
            <option>All chapters</option>
            <option>Faith and worship</option>
            <option>Character</option>
            <option>Community</option>
          </select>
        </div>
      </div>

      <div class="list">
        {normalizedHadiths.length ? (
          normalizedHadiths.map((hadith, index) => (
            <article
              class={`card anim-fade-up anim-delay-${(index % 3) + 1}`}
              data-hadith-number={hadith.number}
              data-share-url={`/hadees/${book.slug}-${hadith.number}`}
            >
              <div class="card__title">Hadith {hadith.number}</div>
              {hadith.chapterMeta ? (
                <div class="card__meta" style="margin-bottom: 12px;">
                  {formatChapterMeta(hadith.chapterMeta)}
                </div>
              ) : null}
              {hadith.narrator ? (
                <p class="hadith-narrator" style="margin-bottom: 8px;"><strong>{hadith.narrator}</strong></p>
              ) : null}
              {hadith.arab ? (
                <p class="hadith-arabic arabic-text" style="font-size: 1.25rem; line-height: 2; margin-bottom: 16px; direction: rtl; text-align: right;">
                  {hadith.arab}
                </p>
              ) : null}
              <p class="hadith-english muted" style="margin-bottom: 16px;">{hadith.text || "Translation unavailable."}</p>
              {hadith.referenceItems.length ? (
                <div class="hadith-reference reference-block">
                  {hadith.referenceItems.map((item) => (
                    <div class="reference-row">
                      <span class="reference-label">{item.label}</span>
                      <span class="reference-value">
                        {item.link ? (
                          <a href={item.link} target="_blank" rel="noreferrer">
                            {item.value}
                          </a>
                        ) : (
                          item.value
                        )}
                      </span>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="hadith-reference card__meta">Reference unavailable.</div>
              )}
              <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px;">
                <button class="btn btn--secondary copy-hadith-btn">Copy</button>
                <button class="btn btn--ghost" type="button" data-share-trigger>Share</button>
              </div>
            </article>
          ))
        ) : (
          <div class="card">
            <strong>No hadiths available.</strong>
            <p class="muted">Try refreshing or selecting another collection.</p>
          </div>
        )}
      </div>

      <div class="card" style="margin-top: 24px;">
        <strong>Page {currentPage} of {totalPages}</strong>
        <p class="muted">
          Showing {normalizedHadiths.length} hadiths on this page (Total: {totalHadiths} hadiths in {book.title})
        </p>
        <div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap; align-items: center;">
          {currentPage > 1 ? (
            <>
              <a class="btn btn--secondary" href={`/hadees/${book.slug}`}>First</a>
              <a class="btn btn--secondary" href={`/hadees/${book.slug}${currentPage - 1 === 1 ? '' : `/${currentPage - 1}`}`}>Previous</a>
            </>
          ) : null}

          <span class="muted" style="padding: 0 12px;">
            Page {currentPage} of {totalPages}
          </span>

          {currentPage < totalPages ? (
            <>
              <a class="btn btn--secondary" href={`/hadees/${book.slug}/${currentPage + 1}`}>Next</a>
              <a class="btn btn--secondary" href={`/hadees/${book.slug}/${totalPages}`}>Last</a>
            </>
          ) : null}
        </div>
      </div>
      </div>
    </section>
    <HadithShareDialog />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButtons = document.querySelectorAll('.copy-hadith-btn');

    copyButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const article = button.closest('article');
        const arabicText = article.querySelector('.hadith-arabic')?.textContent.trim() || '';
        const narrator = article.querySelector('.hadith-narrator')?.textContent.trim() || '';
        const englishText = article.querySelector('.hadith-english')?.textContent.trim() || '';
        const reference = article.querySelector('.hadith-reference')?.textContent.trim() || '';

        // Build the formatted text
        let textToCopy = '';
        if (arabicText) {
          textToCopy += arabicText + '\n\n';
        }
        if (narrator) {
          textToCopy += narrator + '\n';
        }
        if (englishText) {
          textToCopy += englishText + '\n\n';
        }
        if (reference) {
          textToCopy += reference;
        }

        try {
          await navigator.clipboard.writeText(textToCopy.trim());
          const originalText = button.textContent;
          button.textContent = 'Copied!';
          button.style.background = 'var(--color-success, #22c55e)';

          setTimeout(() => {
            button.textContent = originalText;
            button.style.background = '';
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
          button.textContent = 'Failed';
          setTimeout(() => {
            button.textContent = 'Copy';
          }, 2000);
        }
      });
    });
  });
</script>
