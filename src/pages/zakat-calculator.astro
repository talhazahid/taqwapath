  const dynamicText = {
    english: {
      nisabSilver: "Silver nisab used for accessibility.",
      nisabGold: "Gold nisab used.",
      dueIfHawl: "Zakat is due if hawl is met.",
      belowNisab: "Below nisab threshold.",
      hawlMissing: "Hawl not confirmed.",
      copySuccess: "Amount copied to clipboard.",
      copyFailure: "Copy failed. Please copy manually."
    },
    urdu: {
      nisabSilver: "آسانی کے لیے چاندی کا نصاب استعمال کیا گیا۔",
      nisabGold: "سونے کا نصاب استعمال کیا گیا۔",
      dueIfHawl: "اگر حول مکمل ہے تو زکوٰۃ واجب ہے۔",
