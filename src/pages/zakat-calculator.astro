      copyFailure: "کاپی ناکام رہی۔ براہ کرم دستی طور پر کاپی کریں۔"
    },
    bangla: {
      nisabSilver: "সহজতার জন্য রূপার নিসাব ব্যবহার করা হয়েছে।",
      nisabGold: "সোনার নিসাব ব্যবহার করা হয়েছে।",
      dueIfHawl: "হাওল পূর্ণ হলে যাকাত প্রাপ্য।",
      belowNisab: "নিসাবের নিচে।",
