      copySuccess: "পরিমাণ ক্লিপবোর্ডে কপি হয়েছে।",
      copyFailure: "কপি ব্যর্থ হয়েছে। অনুগ্রহ করে হাতে কপি করুন।"
    }
  };

  const getActiveLang = () => languageRoot?.dataset.activeLang || "english";
  const applyTranslations = (lang) => {
    const table = translations[lang] || translations.english;
    i18nElements.forEach((el) => {
      const key = el.dataset.i18n;
      if (!key) return;
      const text = table[key] ?? translations.english[key];
      if (typeof text === "string") el.textContent = text;
    });
  };

  const form = document.querySelector("[data-zakat-form]");
  if (form) {
    const inputs = Array.from(form.querySelectorAll("input[data-field]"));
    const currencySelect = document.querySelector("[data-currency]");
    const hawlCheck = document.querySelector("[data-hawl]");
    const output = {
      assets: document.querySelector('[data-output="assets"]'),
      liabilities: document.querySelector('[data-output="liabilities"]'),
      net: document.querySelector('[data-output="net"]'),
      nisab: document.querySelector('[data-output="nisab"]'),
      due: document.querySelector('[data-output="due"]'),
      nisabNote: document.querySelector('[data-output="nisab-note"]')
    };
    const goldRateValue = document.querySelector('[data-i18n="zakat.goldRate.value"]');
    const silverRateValue = document.querySelector('[data-i18n="zakat.silverRate.value"]');
    const copyBtn = document.querySelector("[data-copy]");
    const copyStatus = document.querySelector("[data-copy-status]");

    const BASE_CURRENCY = "PKR";
    const BASE_GOLD_RATE = 21000;
    const BASE_SILVER_RATE = 260;
    const TOLA_TO_GRAM = 11.6638;
    let currencyRates = { PKR: 1 };
    const currencyLocales = {
      PKR: "en-PK",
      USD: "en-US",
      EUR: "en-IE",
      GBP: "en-GB",
      SAR: "en-SA",
      AED: "en-AE",
      CAD: "en-CA",
      AUD: "en-AU",
      INR: "en-IN",
      BDT: "en-BD",
      TRY: "tr-TR",
      MYR: "ms-MY",
      IDR: "id-ID",
      NGN: "en-NG",
      ZAR: "en-ZA"
    };
    const fallbackRates = {
      PKR: 1,
      USD: 0.0036,
      EUR: 0.0033,
      GBP: 0.0028,
      SAR: 0.0135,
      AED: 0.0132,
      CAD: 0.0049,
      AUD: 0.0055,
      INR: 0.30,
      BDT: 0.39,
      TRY: 0.12,
      MYR: 0.017,
      IDR: 58.2,
      NGN: 5.4,
      ZAR: 0.065
    };

    const getCurrency = () => (currencySelect ? currencySelect.value : "PKR");
    const getRate = () => currencyRates[getCurrency()] || fallbackRates[getCurrency()] || 1;
    const convertFromBase = (value) => value * getRate();
    const formatCurrencyOptionLabel = (currency) => {
      try {
        const parts = new Intl.NumberFormat(currencyLocales[currency] || "en", {
          style: "currency",
          currency,
          currencyDisplay: "narrowSymbol",
          maximumFractionDigits: 0
        }).formatToParts(1);
        const symbol = parts.find((part) => part.type === "currency")?.value;
        return symbol && symbol !== currency ? `${currency} - ${symbol}` : currency;
      } catch {
        return currency;
      }
    };

    const formatMoney = (value) => {
      const currency = getCurrency();
      return new Intl.NumberFormat(currencyLocales[currency] || "en", {
        style: "currency",
        currency,
        currencyDisplay: "symbol",
        maximumFractionDigits: 2
      }).format(value || 0);
    };

    const updateRateLabels = () => {
      if (goldRateValue) goldRateValue.textContent = `${formatMoney(convertFromBase(BASE_GOLD_RATE))} per gram`;
      if (silverRateValue) silverRateValue.textContent = `${formatMoney(convertFromBase(BASE_SILVER_RATE))} per gram`;
    };

    if (currencySelect) {
      Array.from(currencySelect.options).forEach((option) => {
        option.textContent = formatCurrencyOptionLabel(option.value);
      });
    }

    const getValue = (name) => {
      const field = form.querySelector(`[data-field="${name}"]`);
      return field ? Number(field.value) || 0 : 0;
    };

    const getDynamicText = (key) => {
      const lang = getActiveLang();
      return dynamicText[lang]?.[key] || dynamicText.english[key] || "";
    };

    const compute = () => {
      const cash =
        getValue("cash-hand") +
        getValue("cash-savings") +
        getValue("loans-given") +
        getValue("investments") +
        getValue("trade-goods");

      const goldWeight = getValue("gold-weight");
      const silverWeight = getValue("silver-weight");
      const goldUnit = form.querySelector('[data-unit="gold"]')?.value || "grams";
      const silverUnit = form.querySelector('[data-unit="silver"]')?.value || "grams";

      const goldGrams = goldUnit === "tola" ? goldWeight * TOLA_TO_GRAM : goldWeight;
      const silverGrams = silverUnit === "tola" ? silverWeight * TOLA_TO_GRAM : silverWeight;

      const goldRate = convertFromBase(BASE_GOLD_RATE);
      const silverRate = convertFromBase(BASE_SILVER_RATE);
      const metals = goldGrams * goldRate + silverGrams * silverRate;

      const liabilities =
        getValue("liability-credit") +
        getValue("liability-wages") +
        getValue("liability-bills") +
        getValue("liability-other");

      const assets = cash + metals;
      const net = Math.max(assets - liabilities, 0);

      const nisabGold = goldRate * 87.48;
      const nisabSilver = silverRate * 612.36;
      const nisab = Math.min(nisabGold, nisabSilver);
      const nisabLabel = nisab === nisabSilver ? getDynamicText("nisabSilver") : getDynamicText("nisabGold");
      const nisabStatus = net >= nisab ? getDynamicText("dueIfHawl") : getDynamicText("belowNisab");

      const due = net >= nisab ? net * 0.025 : 0;

      output.assets.textContent = formatMoney(assets);
      output.liabilities.textContent = formatMoney(liabilities);
      output.net.textContent = formatMoney(net);
      output.nisab.textContent = formatMoney(nisab);
      output.due.textContent = formatMoney(due);
      output.nisabNote.textContent = `${nisabLabel} ${nisabStatus}`.trim();
      updateRateLabels();

      if (hawlCheck && !hawlCheck.checked) {
        output.nisabNote.textContent += ` ${getDynamicText("hawlMissing")}`;
      }
    };

    const resetForm = () => {
      inputs.forEach((input) => {
        input.value = "";
      });
      compute();
    };

    inputs.forEach((input) => input.addEventListener("input", compute));
    form.querySelectorAll("select").forEach((select) => select.addEventListener("change", compute));
    currencySelect?.addEventListener("change", compute);
    hawlCheck?.addEventListener("change", compute);
    document.querySelector("[data-reset]")?.addEventListener("click", resetForm);

    copyBtn?.addEventListener("click", async () => {
      const text = output.due?.textContent || "";
      try {
        await navigator.clipboard.writeText(text);
        if (copyStatus) copyStatus.textContent = getDynamicText("copySuccess");
      } catch {
        if (copyStatus) copyStatus.textContent = getDynamicText("copyFailure");
      }
    });

    const updateLanguage = (lang) => {
      if (languageRoot) languageRoot.dataset.activeLang = lang;
      applyTranslations(lang);
      if (copyStatus) copyStatus.textContent = "";
      compute();
    };

    const loadCurrencyRates = async () => {
      try {
        const response = await fetch(`https://open.er-api.com/v6/latest/${BASE_CURRENCY}`);
        if (!response.ok) throw new Error("Exchange rate request failed.");
        const payload = await response.json();
        if (payload?.rates && typeof payload.rates === "object") {
          currencyRates = { ...fallbackRates, ...payload.rates, PKR: 1 };
          compute();
        }
      } catch {
        currencyRates = { ...fallbackRates };
        compute();
      }
    };

    languageInputs.forEach((input) => {
      input.addEventListener("change", () => updateLanguage(input.value));
    });

    updateLanguage(getActiveLang());
    loadCurrencyRates();
  }
</script>
