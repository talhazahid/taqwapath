---
import BaseLayout from "../layouts/BaseLayout.astro";

const currencyOptions = typeof Intl.supportedValuesOf === "function"
  ? Intl.supportedValuesOf("currency")
  : ["PKR", "USD", "EUR", "GBP", "SAR", "AED", "CAD", "AUD", "INR", "BDT"];
const orderedCurrencies = ["PKR", ...currencyOptions.filter((currency) => currency !== "PKR")];
---
<BaseLayout
  title="Zakat Calculator (Gold, Silver, Cash) - TaqwaPath"
  description="Calculate zakat online with nisab thresholds, gold and silver rates, and live totals."
  faqItems={[
    {
      question: "What assets are included in Zakat?",
      answer: "Common zakatable assets include cash, bank balances, savings, receivables, investments, gold, silver, and business stock intended for sale."
    },
    {
      question: "What is nisab?",
      answer: "Nisab is the minimum threshold used to determine whether zakat may be due. This calculator compares gold and silver thresholds and uses the lower value for accessibility."
    },
    {
      question: "Is the Zakat calculator a final religious ruling?",
      answer: "No. The calculation is an estimate for convenience. Zakat rulings can vary by asset type, school of thought, and personal situation."
    }
  ]}
>
  <section class="section">
    <div class="container">
      <div class="chapter-layout" data-language-root data-active-lang="english">
        <aside class="language-panel" data-language-switcher>
          <div class="language-panel__title">Language</div>
          <label class="language-option">
            <input type="radio" name="zakat-language" value="english" checked />
            <span>English</span>
          </label>
          <label class="language-option">
            <input type="radio" name="zakat-language" value="urdu" />
            <span>Urdu</span>
          </label>
          <label class="language-option">
            <input type="radio" name="zakat-language" value="bangla" />
            <span>Bangla</span>
          </label>
        </aside>

        <div class="chapter-content">
          <span class="pill" data-i18n="zakat.pill">Zakat Calculator</span>
          <h1 class="section-title" data-i18n="zakat.title">Calculate your zakat</h1>
          <p class="section-lead" data-i18n="zakat.lead">
            Based on the nisab threshold and hawl condition. Totals update live as you type.
          </p>
          <div class="card card--white" style="margin-bottom: 24px;">
            <h2 class="card__title">Calculate Zakat on cash, gold, silver, investments, and trade goods</h2>
            <p class="muted">
              This Zakat calculator estimates zakat due at 2.5 percent after comparing net zakatable wealth with the nisab threshold. Add cash, savings, loans given, investments, gold, silver, trade goods, and deductible liabilities to see total assets, total liabilities, net zakatable wealth, nisab, and estimated zakat due. The result is a practical estimate and should be checked with a qualified scholar for personal cases.
            </p>
          </div>

          <div class="card" style="margin-bottom: 24px;">
            <div class="grid grid--3">
              <div>
                <div class="card__title" data-i18n="zakat.goldRate.title">Gold rate</div>
                <div class="muted" data-i18n="zakat.goldRate.value">PKR 21,000 per gram</div>
                <div class="tag" data-i18n="zakat.updatedToday">Updated today</div>
              </div>
              <div>
                <div class="card__title" data-i18n="zakat.silverRate.title">Silver rate</div>
                <div class="muted" data-i18n="zakat.silverRate.value">PKR 260 per gram</div>
                <div class="tag" data-i18n="zakat.updatedToday">Updated today</div>
              </div>
              <div>
                <div class="card__title" data-i18n="zakat.currency.title">Currency</div>
                <select class="select" data-currency>
                  {orderedCurrencies.map((currency) => (
                    <option value={currency} selected={currency === "PKR"}>{currency}</option>
                  ))}
                </select>
              </div>
            </div>
          </div>

          <div class="calc-layout" data-zakat-form>
            <div class="grid" style="gap: 24px;">
              <div class="card">
                <div class="card__title" data-i18n="zakat.cash.title">1. Cash</div>
                <div class="form-grid">
                  <div class="field">
                    <label for="cash-hand" data-i18n="zakat.cash.hand">Cash in hand and bank</label>
                    <input class="input" id="cash-hand" type="number" min="0" step="0.01" data-field="cash-hand" />
                  </div>
                  <div class="field">
                    <label for="cash-savings" data-i18n="zakat.cash.savings">Cash saved for future purpose</label>
                    <input class="input" id="cash-savings" type="number" min="0" step="0.01" data-field="cash-savings" />
                  </div>
                  <div class="field">
                    <label for="loans-given" data-i18n="zakat.cash.loans">Loans given out</label>
                    <input class="input" id="loans-given" type="number" min="0" step="0.01" data-field="loans-given" />
                  </div>
                </div>
              </div>

              <div class="card">
                <div class="card__title" data-i18n="zakat.investments.title">2. Investments</div>
                <div class="form-grid">
                  <div class="field">
                    <label for="investments" data-i18n="zakat.investments.label">Investments and shares</label>
                    <input class="input" id="investments" type="number" min="0" step="0.01" data-field="investments" />
                  </div>
                </div>
              </div>

              <div class="card">
                <div class="card__title" data-i18n="zakat.metals.title">3. Gold and Silver</div>
                <div class="form-grid">
                  <div class="field">
                    <label for="gold-weight" data-i18n="zakat.metals.goldWeight">Gold weight</label>
                    <div class="form-row" style="grid-template-columns: 1fr 140px;">
                      <input class="input" id="gold-weight" type="number" min="0" step="0.01" data-field="gold-weight" />
                      <select class="select" data-unit="gold">
                        <option value="grams" data-i18n="zakat.unit.grams">grams</option>
                        <option value="tola" data-i18n="zakat.unit.tola">tola</option>
                      </select>
                    </div>
                  </div>
                  <div class="field">
                    <label for="silver-weight" data-i18n="zakat.metals.silverWeight">Silver weight</label>
                    <div class="form-row" style="grid-template-columns: 1fr 140px;">
                      <input class="input" id="silver-weight" type="number" min="0" step="0.01" data-field="silver-weight" />
                      <select class="select" data-unit="silver">
                        <option value="grams" data-i18n="zakat.unit.grams">grams</option>
                        <option value="tola" data-i18n="zakat.unit.tola">tola</option>
                      </select>
                    </div>
                  </div>
                  <div class="tag" data-i18n="zakat.metals.tolaNote">1 tola = 11.6638 grams</div>
                </div>
              </div>

              <div class="card">
                <div class="card__title" data-i18n="zakat.trade.title">4. Trade Goods</div>
                <div class="form-grid">
                  <div class="field">
                    <label for="trade-goods" data-i18n="zakat.trade.label">Value of stock intended for sale</label>
                    <input class="input" id="trade-goods" type="number" min="0" step="0.01" data-field="trade-goods" />
                  </div>
                </div>
              </div>

              <div class="card">
                <div class="card__title" data-i18n="zakat.liabilities.title">5. Liabilities (deduct)</div>
                <div class="form-grid">
                  <div class="field">
                    <label for="liability-credit" data-i18n="zakat.liabilities.credit">Goods bought on credit</label>
                    <input class="input" id="liability-credit" type="number" min="0" step="0.01" data-field="liability-credit" />
                  </div>
                  <div class="field">
                    <label for="liability-wages" data-i18n="zakat.liabilities.wages">Wages due</label>
                    <input class="input" id="liability-wages" type="number" min="0" step="0.01" data-field="liability-wages" />
                  </div>
                  <div class="field">
                    <label for="liability-bills" data-i18n="zakat.liabilities.bills">Taxes, rent, utilities due</label>
                    <input class="input" id="liability-bills" type="number" min="0" step="0.01" data-field="liability-bills" />
                  </div>
                  <div class="field">
                    <label for="liability-other" data-i18n="zakat.liabilities.other">Other liability</label>
                    <input class="input" id="liability-other" type="number" min="0" step="0.01" data-field="liability-other" />
                  </div>
                </div>
              </div>
            </div>

            <aside class="card calc-summary">
              <div class="card__title" data-i18n="zakat.summary.title">Zakat Summary</div>
              <div class="summary-row">
                <span data-i18n="zakat.summary.assets">Total assets</span>
                <strong data-output="assets">PKR 0</strong>
              </div>
              <div class="summary-row">
                <span data-i18n="zakat.summary.liabilities">Total liabilities</span>
                <strong data-output="liabilities">PKR 0</strong>
              </div>
              <div class="summary-row">
                <span data-i18n="zakat.summary.net">Net zakatable wealth</span>
                <strong data-output="net">PKR 0</strong>
              </div>
              <div class="summary-row">
                <span data-i18n="zakat.summary.nisab">Nisab threshold used</span>
                <strong data-output="nisab">PKR 0</strong>
              </div>
              <div class="summary-row">
                <span data-i18n="zakat.summary.due">Zakat due (2.5%)</span>
                <strong data-output="due">PKR 0</strong>
              </div>
              <p class="summary-note" data-output="nisab-note" data-lang-text>
                Zakat is due when net wealth is above nisab.
              </p>
              <label class="summary-note" style="display: flex; gap: 8px; align-items: center;">
                <input type="checkbox" data-hawl />
                <span data-i18n="zakat.hawl.label">I have owned this wealth for one lunar year (hawl)</span>
              </label>
              <div style="display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap;">
                <button class="btn btn--secondary" type="reset" data-reset data-i18n="zakat.button.reset">Reset</button>
                <button class="btn btn--primary" type="button" data-copy data-i18n="zakat.button.copy">Copy amount</button>
              </div>
              <div class="summary-note" data-copy-status data-lang-text style="margin-top: 10px;"></div>
            </aside>
          </div>
        </div>

        <div class="grid grid--3" style="margin-top: 24px;">
          <div class="card">
            <h2 class="card__title">What assets are included in Zakat?</h2>
            <p class="muted">Common zakatable assets include cash, bank balances, savings, receivables, investments, gold, silver, and business stock intended for sale.</p>
          </div>
          <div class="card">
            <h2 class="card__title">What is nisab?</h2>
            <p class="muted">Nisab is the minimum threshold used to determine whether zakat may be due. This calculator compares gold and silver thresholds and uses the lower value for accessibility.</p>
          </div>
          <div class="card">
            <h2 class="card__title">Is this a final religious ruling?</h2>
            <p class="muted">No. The calculation is an estimate for convenience. Zakat rulings can vary by asset type, school of thought, and personal situation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const languageRoot = document.querySelector("[data-language-root]");
  const languageInputs = document.querySelectorAll("[data-language-switcher] input[type=\"radio\"]");
  const i18nElements = Array.from(document.querySelectorAll("[data-i18n]"));
  const translations = {
