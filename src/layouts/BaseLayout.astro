---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import Header from "../components/Header.astro";
import DateStrip from "../components/DateStrip.astro";
import Footer from "../components/Footer.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import { prayerLocations } from "../data/prayerLocations.js";

const {
  title = "TaqwaPath",
  description = "A modern Islamic utility site for daily worship, learning, and reflection.",
  showDateStrip = true,
  canonicalPath: canonicalPathOverride,
  faqItems = []
} = Astro.props;

const siteUrl = (Astro.site?.toString() || "https://taqwapath.com").replace(/\/+$/, "");
const normalizePathname = (pathname = "/") => {
  if (!pathname || pathname === "/") return "/";
  return pathname.replace(/\/+$/, "");
};
const canonicalPath = normalizePathname(canonicalPathOverride || Astro.url.pathname);
const canonical = canonicalPath === "/" ? siteUrl : `${siteUrl}${canonicalPath}`;
const ogImage = `${siteUrl}/og-image.png`;
const organizationId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;
const pageId = `${canonical}#webpage`;
const breadcrumbItems = canonicalPath === "/"
  ? []
  : canonicalPath
      .split("/")
      .filter(Boolean)
      .map((segment, index, segments) => {
        const pathPart = `/${segments.slice(0, index + 1).join("/")}`;
        const name = segment
          .replace(/-/g, " ")
          .replace(/\b\w/g, (letter) => letter.toUpperCase());
        return {
          "@type": "ListItem",
          position: index + 1,
          name,
          item: `${siteUrl}${pathPart}`
        };
      });
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": organizationId,
      name: "TaqwaPath",
      url: siteUrl,
      logo: {
        "@type": "ImageObject",
        url: ogImage,
        width: 1200,
        height: 630
      },
      sameAs: [
        "https://github.com/talhazahid/taqwapath",
        "https://play.google.com/store/apps/details?id=com.taqwapath.taqwapath_mobile"
      ],
      description: "TaqwaPath is a calm Islamic utility for Salah timings, Quran recitations, Hadith search, Zakat calculation, Hijri dates, Islamic calendar pages, and Ramadan references."
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      name: "TaqwaPath",
      url: siteUrl,
      publisher: {
        "@id": organizationId
      },
      potentialAction: {
        "@type": "SearchAction",
        target: `${siteUrl}/hadith?search={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "WebPage",
      "@id": pageId,
      name: title,
      description,
      url: canonical,
      inLanguage: "en",
      isPartOf: {
        "@id": websiteId
      },
      about: {
        "@id": organizationId
      },
      publisher: {
        "@id": organizationId
      },
      dateModified: new Date().toISOString().split("T")[0]
    },
    ...(breadcrumbItems.length
      ? [
          {
            "@type": "BreadcrumbList",
            "@id": `${canonical}#breadcrumb`,
            itemListElement: [
              {
                "@type": "ListItem",
                position: 1,
                name: "Home",
                item: siteUrl
              },
              ...breadcrumbItems.map((item) => ({
                ...item,
                position: item.position + 1
              }))
            ]
          }
        ]
      : [])
  ]
};
const trustJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/about#maintainer`,
  name: "Talha Zahid",
  url: `${siteUrl}/about`,
  affiliation: {
    "@id": organizationId
  }
};
const faqJsonLd = Array.isArray(faqItems) && faqItems.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      mainEntity: faqItems
        .filter((item) => item?.question && item?.answer)
        .map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer
          }
        }))
    }
  : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-adsense-account" content="ca-pub-1039785764922996" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#f5f6f3" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="TaqwaPath" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:image" content={ogImage} />
    <ViewTransitions />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-E9TFE950EH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-E9TFE950EH');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(trustJsonLd)} />
    {faqJsonLd ? <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600;700&family=Noto+Naskh+Arabic:wght@400;600&family=Noto+Nastaliq+Urdu:wght@400;700&family=Noto+Sans+Bengali:wght@400;600;700&family=Sora:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page">
      <Header />
      {showDateStrip ? <DateStrip /> : null}
      <main class="main">
        <slot />
      </main>
      <Footer />
    </div>
    <AudioPlayer />
    <script define:vars={{ prayerLocations }}>
      (() => {
        const defaultRoute = { countrySlug: "pakistan", citySlug: "karachi" };
        const prayerSuffix = "-prayer-times";

        const normalizeValue = (value = "") =>
          String(value)
            .trim()
            .toLowerCase()
            .replace(/&/g, " and ")
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-+|-+$/g, "")
            .replace(/-{2,}/g, "-");

        const routePath = (countrySlug, citySlug) => `/world/${countrySlug}/${citySlug}`;

        const findCountry = (countrySlug) =>
          prayerLocations.find((entry) => entry.countrySlug === countrySlug);

        const findCity = (country, citySlug) =>
          country?.cities?.find((entry) => entry.slug === citySlug);

        const isValidRoute = (countrySlug, citySlug) => {
          const country = findCountry(countrySlug);
          const city = findCity(country, citySlug);
          return Boolean(country && city);
        };

        const parseWorldPath = (pathname = window.location.pathname) => {
          const parts = String(pathname).replace(/^\/+|\/+$/g, "").split("/");
          if (parts.length < 3 || parts[0] !== "world") return null;
          const countrySlug = parts[1];
          const rawCitySlug = parts[2];
          const citySlug = rawCitySlug.endsWith(prayerSuffix)
            ? rawCitySlug.slice(0, -prayerSuffix.length)
            : rawCitySlug;
          if (!isValidRoute(countrySlug, citySlug)) return null;
          return { countrySlug, citySlug };
        };

        const resolveByNames = (countryName, cityName) => {
          const normalizedCountry = normalizeValue(countryName);
          const normalizedCity = normalizeValue(cityName);
          if (!normalizedCountry || !normalizedCity) return null;
          const country = prayerLocations.find(
            (entry) => normalizeValue(entry.country) === normalizedCountry
          );
          if (!country) return null;
          const city = country.cities.find(
            (entry) => normalizeValue(entry.name) === normalizedCity
          );
          if (!city) return null;
          return { countrySlug: country.countrySlug, citySlug: city.slug };
        };

        const resolveByCountryOnly = (countryName) => {
          const normalizedCountry = normalizeValue(countryName);
          if (!normalizedCountry) return null;
          const country = prayerLocations.find(
            (entry) => normalizeValue(entry.country) === normalizedCountry
          );
          const city = country?.cities?.[0];
          if (!country || !city) return null;
          return { countrySlug: country.countrySlug, citySlug: city.slug };
        };

        const readStoredRoute = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem("taqwapath.salah.route") || "");
            if (!parsed?.countrySlug || !parsed?.citySlug) return null;
            if (!isValidRoute(parsed.countrySlug, parsed.citySlug)) return null;
            return { countrySlug: parsed.countrySlug, citySlug: parsed.citySlug };
          } catch {
            return null;
          }
        };

        const storeRoute = (route) => {
          if (!route?.countrySlug || !route?.citySlug) return;
          const country = findCountry(route.countrySlug);
          const city = findCity(country, route.citySlug);
          if (!country || !city) return;

          try {
            localStorage.setItem(
              "taqwapath.salah.route",
              JSON.stringify({
                countrySlug: country.countrySlug,
                citySlug: city.slug
              })
            );
          } catch {
            // Ignore storage errors.
          }

          try {
            localStorage.setItem(
              "taqwapath.location",
              JSON.stringify({
                country: country.country,
                city: city.name
              })
            );
          } catch {
            // Ignore storage errors.
          }
        };

        const resolveFromNavigator = () =>
          new Promise((resolve) => {
            if (!navigator.geolocation) {
              resolve(null);
              return;
            }

            navigator.geolocation.getCurrentPosition(
              async (position) => {
                try {
                  const lat = position.coords?.latitude;
                  const lon = position.coords?.longitude;
                  if (!Number.isFinite(lat) || !Number.isFinite(lon)) {
                    resolve(null);
                    return;
                  }

                  const url =
                    `https://nominatim.openstreetmap.org/reverse?format=jsonv2` +
                    `&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lon)}` +
                    `&addressdetails=1`;
                  const response = await fetch(url);
                  if (!response.ok) {
                    resolve(null);
                    return;
                  }
                  const data = await response.json();
                  const address = data?.address || {};
                  const countryName = address.country || "";
                  const cityName =
                    address.city ||
                    address.town ||
                    address.village ||
                    address.county ||
                    address.state_district ||
                    "";

                  resolve(
                    resolveByNames(countryName, cityName) || resolveByCountryOnly(countryName)
                  );
                } catch {
                  resolve(null);
                }
              },
              () => resolve(null),
              { enableHighAccuracy: false, timeout: 6000, maximumAge: 3600000 }
            );
          });

        const resolveFromIp = async () => {
          try {
            const response = await fetch("https://ipapi.co/json/");
            if (!response.ok) return null;
            const data = await response.json();
            return (
              resolveByNames(data?.country_name, data?.city) ||
              resolveByCountryOnly(data?.country_name)
            );
          } catch {
            return null;
          }
        };

        let routePromise = null;

        const resolveRoute = (forceRefresh = false) => {
          if (forceRefresh) routePromise = null;
          if (routePromise) return routePromise;

          routePromise = (async () => {
            const routeFromPath = parseWorldPath();
            if (routeFromPath) {
              storeRoute(routeFromPath);
              return routeFromPath;
            }

            const storedRoute = readStoredRoute();
            if (storedRoute) {
              storeRoute(storedRoute);
              return storedRoute;
            }

            const navigatorRoute = await resolveFromNavigator();
            if (navigatorRoute) {
              storeRoute(navigatorRoute);
              return navigatorRoute;
            }

            const ipRoute = await resolveFromIp();
            if (ipRoute) {
              storeRoute(ipRoute);
              return ipRoute;
            }

            storeRoute(defaultRoute);
            return defaultRoute;
          })();

          return routePromise;
        };

        window.__resolveTaqwaSalahRoute = resolveRoute;
        window.__getTaqwaSalahPath = async () => {
          const route = await resolveRoute();
          return routePath(route.countrySlug, route.citySlug);
        };

        resolveRoute();
      })();
    </script>
    <script>
      import "../scripts/hadith-interactions.js";
    </script>
  </body>
</html>
